"""
Utilities for UV package manager integration with MLflow.
"""

import logging
import os
import shutil
import subprocess
from pathlib import Path
from typing import Optional

from mlflow.environment_variables import (
    MLFLOW_UV_AUTO_DETECT,
    MLFLOW_UV_PROJECT_PATH,
)
from mlflow.exceptions import MlflowException

_logger = logging.getLogger(__name__)

_UV_LOCK_FILE = "uv.lock"
_PYPROJECT_TOML = "pyproject.toml"


def _is_uv_project(path: str | Path) -> bool:
    """
    Check if the given path contains a UV project (uv.lock + pyproject.toml).

    Args:
        path: The path to check for UV project files.

    Returns:
        True if both uv.lock and pyproject.toml exist in the path, False otherwise.
    """
    path = Path(path)
    return (path / _UV_LOCK_FILE).exists() and (path / _PYPROJECT_TOML).exists()


def _find_uv_project_path(start_path: str | Path) -> Optional[Path]:
    """
    Find the UV project path starting from the given path.

    If MLFLOW_UV_PROJECT_PATH is set, use that. Otherwise, check if the start_path
    or any of its parents contain a UV project.

    Args:
        start_path: The path to start searching from.

    Returns:
        The path to the UV project if found, None otherwise.
    """
    # Check explicit project path first
    explicit_path = MLFLOW_UV_PROJECT_PATH.get()
    if explicit_path:
        explicit_path = Path(explicit_path)
        if _is_uv_project(explicit_path):
            return explicit_path
        _logger.warning(
            f"MLFLOW_UV_PROJECT_PATH is set to '{explicit_path}' but no UV project found there."
        )

    # Auto-detect if enabled (default True)
    if not MLFLOW_UV_AUTO_DETECT.get():
        return None

    # Search from start_path upwards
    current = Path(start_path).resolve()
    for path in [current] + list(current.parents):
        if _is_uv_project(path):
            return path

    return None


def _uv_binary() -> Optional[str]:
    """Get the path to the uv binary if available."""
    return shutil.which("uv")


def _is_uv_available() -> bool:
    """Check if uv is available in the system PATH."""
    return _uv_binary() is not None


def _export_requirements(
    project_path: str | Path,
    output_path: str | Path,
    timeout: Optional[int] = None,
) -> bool:
    """
    Export locked requirements from a UV project using `uv export`.

    Args:
        project_path: Path to the UV project directory.
        output_path: Path where the requirements.txt will be written.
        timeout: Optional timeout in seconds for the export command.

    Returns:
        True if export succeeded, False otherwise.
    """
    uv_bin = _uv_binary()
    if uv_bin is None:
        _logger.debug("uv binary not found, skipping UV export")
        return False

    project_path = Path(project_path)
    output_path = Path(output_path)

    if not _is_uv_project(project_path):
        _logger.debug(f"No UV project found at '{project_path}'")
        return False

    cmd = [
        uv_bin,
        "export",
        "--format=requirements-txt",
        f"--project={project_path}",
        f"--output-file={output_path}",
        "--no-header",
        "--no-editable",
    ]

    try:
        _logger.info(f"Exporting UV requirements from '{project_path}' to '{output_path}'")
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=timeout,
            check=True,
        )
        return True
    except subprocess.CalledProcessError as e:
        _logger.warning(f"Failed to export UV requirements: {e.stderr}")
        return False
    except subprocess.TimeoutExpired:
        _logger.warning(f"UV export timed out after {timeout} seconds")
        return False
    except Exception as e:
        _logger.warning(f"Unexpected error during UV export: {e}")
        return False


def get_uv_requirements(
    model_path: str | Path,
    timeout: Optional[int] = None,
) -> Optional[Path]:
    """
    Get requirements from a UV project if available.

    This function attempts to find a UV project related to the model and export
    its locked requirements. If UV is not available or no project is found,
    returns None to allow fallback to standard inference.

    Args:
        model_path: Path to the model directory.
        timeout: Optional timeout for the export command.

    Returns:
        Path to the exported requirements file if successful, None otherwise.
    """
    if not _is_uv_available():
        _logger.debug("UV not available, skipping UV requirements export")
        return None

    uv_project = _find_uv_project_path(model_path)
    if uv_project is None:
        return None

    # Create a temporary requirements file
    output_path = Path(model_path) / "uv_requirements.txt"

    if _export_requirements(uv_project, output_path, timeout=timeout):
        return output_path

    return None
