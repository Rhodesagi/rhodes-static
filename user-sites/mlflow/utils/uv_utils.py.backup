"""
Utilities for detecting and exporting dependencies from UV projects.
"""

import os
import shutil
import subprocess
import tempfile
from pathlib import Path

from mlflow.environment_variables import (
    MLFLOW_UV_DETECT,
    MLFLOW_UV_PROJECT_PATH,
    MLFLOW_UV_REQUIREMENTS_EXPORT_TIMEOUT,
)
from mlflow.exceptions import MlflowException


def is_uv_available():
    """Check if uv is available in the system PATH."""
    return shutil.which("uv") is not None


def detect_uv_project(model_path):
    """
    Detect if the given model path contains a UV project (uv.lock and pyproject.toml).
    Returns the path to the UV project directory if detected, otherwise None.
    """
    model_path = Path(model_path)
    # Check for explicit environment variable
    if MLFLOW_UV_PROJECT_PATH.get():
        explicit_path = Path(MLFLOW_UV_PROJECT_PATH.get())
        if explicit_path.exists():
            return explicit_path
        else:
            raise MlflowException(
                f"MLFLOW_UV_PROJECT_PATH points to non-existent directory: {explicit_path}"
            )

    # Auto-detection if enabled (default True)
    if not MLFLOW_UV_DETECT.get():
        return None

    # Check for uv.lock and pyproject.toml in model_path
    if (model_path / "uv.lock").exists() and (model_path / "pyproject.toml").exists():
        return model_path

    # Also check parent directories up to a limit
    for parent in model_path.parents:
        if (parent / "uv.lock").exists() and (parent / "pyproject.toml").exists():
            return parent

    return None


def export_uv_requirements(uv_project_path, output_path=None):
    """
    Export locked requirements from a UV project using `uv export --format requirements`.
    Returns the path to the generated requirements file.
    If uv is not available or export fails, raises MlflowException.
    """
    if not is_uv_available():
        raise MlflowException(
            "UV is not available. Please install uv or disable UV detection."
        )

    uv_project_path = Path(uv_project_path)
    if not uv_project_path.exists():
        raise MlflowException(f"UV project path does not exist: {uv_project_path}")

    if output_path is None:
        # Create a temporary file
        fd, output_path = tempfile.mkstemp(suffix=".txt", prefix="uv_requirements_")
        os.close(fd)
        delete_on_exit = True
    else:
        delete_on_exit = False

    try:
        cmd = [
            "uv",
            "export",
            "--format",
            "requirements",
            "--output",
            output_path,
            "--project",
            str(uv_project_path),
        ]
        timeout = MLFLOW_UV_REQUIREMENTS_EXPORT_TIMEOUT.get()
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
        if result.returncode != 0:
            raise MlflowException(
                f"Failed to export UV requirements: {result.stderr}"
            )
        return output_path
    except subprocess.TimeoutExpired:
        raise MlflowException(
            f"UV export timed out after {timeout} seconds."
        )
    except Exception as e:
        if delete_on_exit:
            try:
                os.unlink(output_path)
            except OSError:
                pass
        raise MlflowException(f"UV export failed: {e}")
    finally:
        if not delete_on_exit:
            # Ensure file is persisted
            pass


def get_uv_requirements(model_path):
    """
    Detect UV project and export its locked requirements.
    Returns a list of requirement strings.
    If no UV project detected or export fails, returns None.
    """
    uv_project = detect_uv_project(model_path)
    if uv_project is None:
        return None

    try:
        req_file = export_uv_requirements(uv_project)
        with open(req_file, "r") as f:
            requirements = [line.strip() for line in f if line.strip()]
        # Clean up temporary file
        os.unlink(req_file)
        return requirements
    except MlflowException:
        # Fallback to other inference methods
        return None


def should_use_uv_requirements(model_path):
    """
    Determine whether to use UV exported requirements for dependency inference.
    Returns True if UV project is detected and UV is available.
    """
    uv_project = detect_uv_project(model_path)
    if uv_project is None:
        return False
    return is_uv_available()