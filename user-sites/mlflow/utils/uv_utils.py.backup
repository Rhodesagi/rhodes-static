"""
Utilities for UV (ultra-fast Python package installer and resolver) integration.
"""

import os
import subprocess
import tempfile
from pathlib import Path
from typing import List, Optional

from mlflow.exceptions import MlflowException


def is_uv_available() -> bool:
    """
    Check if the `uv` command is available in the system PATH.

    Returns:
        bool: True if `uv` is available, False otherwise.
    """
    return shutil.which("uv") is not None


def is_uv_project(path: str | Path) -> bool:
    """
    Check if the given directory is a UV project by looking for `uv.lock` and `pyproject.toml` files.

    Args:
        path: Directory path to check.

    Returns:
        bool: True if both `uv.lock` and `pyproject.toml` exist, False otherwise.
    """
    path = Path(path)
    return (path / "uv.lock").is_file() and (path / "pyproject.toml").is_file()


def export_uv_requirements(
    project_path: str | Path,
    output_format: str = "requirements.txt",
    groups: Optional[List[str]] = None,
) -> str:
    """
    Export locked dependencies from a UV project using `uv export`.

    Args:
        project_path: Path to the UV project directory (containing uv.lock and pyproject.toml).
        output_format: Format of the exported output (default: "requirements.txt").
        groups: Optional list of dependency groups to export.

    Returns:
        str: The exported requirements as a string.

    Raises:
        MlflowException: If `uv` command fails or is not available.
    """
    import shutil
    import subprocess

    if not is_uv_available():
        raise MlflowException("`uv` command is not available in PATH.")

    project_path = Path(project_path)
    if not is_uv_project(project_path):
        raise MlflowException(
            f"Path {project_path} is not a UV project (missing uv.lock or pyproject.toml)."
        )

    cmd = ["uv", "export", "--format", output_format, "--no-hashes"]
    if groups:
        for group in groups:
            cmd.extend(["--group", group])
    cmd.append(str(project_path))

    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            cwd=project_path,
            check=True,
        )
        return result.stdout
    except subprocess.CalledProcessError as e:
        raise MlflowException(
            f"Failed to export UV requirements: {e.stderr}"
        ) from e
    except FileNotFoundError:
        raise MlflowException("`uv` command not found.")


def get_uv_requirements_path(model_path: str | Path) -> Optional[Path]:
    """
    Check if a UV project exists within the model directory and return the path
    to the UV lock file if present.

    Args:
        model_path: Path to the MLflow model directory.

    Returns:
        Optional[Path]: Path to uv.lock if UV project exists, None otherwise.
    """
    model_path = Path(model_path)
    uv_lock = model_path / "uv.lock"
    pyproject = model_path / "pyproject.toml"
    if uv_lock.is_file() and pyproject.is_file():
        return uv_lock
    return None


def detect_and_export_uv_requirements(
    model_path: str | Path,
    output_file: Optional[str | Path] = None,
) -> Optional[str]:
    """
    Detect if the model directory contains a UV project and export its dependencies.
    If output_file is provided, write the exported requirements to that file.

    Args:
        model_path: Path to the MLflow model directory.
        output_file: Optional path to write exported requirements.

    Returns:
        Optional[str]: Exported requirements as string if UV project detected and export
        successful, None otherwise.
    """
    if not is_uv_project(model_path):
        return None

    try:
        requirements = export_uv_requirements(model_path)
        if output_file:
            Path(output_file).write_text(requirements)
        return requirements
    except Exception as e:
        # Log warning but do not fail; fall back to traditional inference
        import logging
        logging.getLogger(__name__).warning(
            "Failed to export UV requirements, falling back to traditional inference: %s", e
        )
        return None