# Binary RISC-V instructions for fib(10)
# Hand-assembled RV32I

import struct

# Instructions (little-endian)
insts = [
    0x00a00513,  # li a0, 10  -> addi x10, x0, 10
    0x00000593,  # li a1, 0   -> addi x11, x0, 0
    0x00100613,  # li a2, 1   -> addi x12, x0, 1
    0x00000693,  # li a3, 0   -> addi x13, x0, 0
    0x00a68463,  # beq a3, a0, done -> beq x13, x10, +8 (offset adjusted)
    0x00c70733,  # add a4, a1, a2 -> add x14, x11, x12
    0x00058633,  # mv a1, a2  -> add x12, x12, 0 (actually: addi x12, x12, 0)
    # Let me recalculate properly...
]

# Actually let me be more careful
# PC starts at 0
# 0:  addi x10, x0, 10   # 0x00a00513
# 4:  addi x11, x0, 0    # 0x00000593
# 8:  addi x12, x0, 1    # 0x00100613
# 12: addi x13, x0, 0    # 0x00000693
# 16: beq x13, x10, 20   # offset = (40-16)/4 = 6 -> 0x00a68463
# 20: add x14, x11, x12  # 0x00c70733
# 24: addi x11, x12, 0   # mv a1, a2 -> 0x00060693
# 28: addi x12, x14, 0   # mv a2, a4 -> 0x00070733
# 32: addi x13, x13, 1   # i++ -> 0x00168693
# 36: jal x0, -20         # j loop -> 0xff1ff06f
# 40: addi x10, x11, 0   # mv a0, a1 -> 0x00050513
# 44: ecall               # 0x00000073

insts = [
    0x00a00513,  # addi a0, x0, 10
    0x00000593,  # addi a1, x0, 0
    0x00100613,  # addi a2, x0, 1
    0x00000693,  # addi a3, x0, 0
    0x00a68463,  # beq a3, a0, 40 (offset=6)
    0x00c70733,  # add a4, a1, a2
    0x00060693,  # addi a3, a2, 0 (mv a1, a2 - wait, wrong reg)
    # Let me fix: mv a1, a2 = addi x11, x12, 0 -> 0x00060693
    # mv a2, a4 = addi x12, x14, 0 -> 0x00070733
    # addi a3, a3, 1 = 0x00168693
    # jal x0, loop = jal x0, -20 -> imm = -20, encoded...
]

# Simpler: just write the binary directly
data = b''
# addi x10, x0, 10
data += struct.pack('<I', 0x00a00513)
# addi x11, x0, 0  
data += struct.pack('<I', 0x00000593)
# addi x12, x0, 1
data += struct.pack('<I', 0x00100613)
# addi x13, x0, 0
data += struct.pack('<I', 0x00000693)
# beq x13, x10, 40 (offset = (40-16)/2 = 12, but encoded differently)
# beq: imm[12|10:5] rs2 rs1 000 imm[4:1|11] 1100011
# target = 40, pc = 16, offset = 24 = 11000
# imm[12]=0, imm[10:5]=000000, imm[4:1]=1000, imm[11]=0
# 0000000 01010 01101 000 01000 1100011 = 0x00a68463
data += struct.pack('<I', 0x00a68463)
# add x14, x11, x12
data += struct.pack('<I', 0x00c70733)
# addi x11, x12, 0 (mv a1, a2)
data += struct.pack('<I', 0x00060693)
# addi x12, x14, 0 (mv a2, a4)
data += struct.pack('<I', 0x00070733)
# addi x13, x13, 1
data += struct.pack('<I', 0x00168693)
# jal x0, -20 (j loop)
# jal: imm[20|10:1|11|19:12] rd 1101111
# offset = -20 = 111111111111111010100
# imm[20]=1, imm[10:1]=1111111010, imm[11]=1, imm[19:12]=11111111
# 1111111111 1 11111111 00000 1101111 = 0xff1ff06f
data += struct.pack('<I', 0xff1ff06f)
# addi x10, x11, 0 (mv a0, a1)
data += struct.pack('<I', 0x00050513)
# ecall
data += struct.pack('<I', 0x00000073)

with open('/var/www/html/user-sites/user_12001/fib.bin', 'wb') as f:
    f.write(data)

print(f"Written {len(data)} bytes")
