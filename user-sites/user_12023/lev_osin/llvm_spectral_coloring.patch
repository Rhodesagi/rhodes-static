+# RUN: llc -o - -mtriple=aarch64-unknown-linux-gnu -regalloc=spectral %s | FileCheck %s
+# REQUIRES: aarch64-registered-target
+
+# Test spectral coloring on simple interference graph
+# The interference forms a "diamond" pattern:
+#   v0 conflicts with v1, v2
+#   v1 conflicts with v0, v3
+#   v2 conflicts with v0, v3
+#   v3 conflicts with v1, v2
+# Optimal coloring requires 2 registers
+# Spectral ordering should achieve this
+
+--- |
+  target triple = "aarch64-unknown-linux-gnu"
+  define void @test_spectral() {
+  entry:
+    %a = add i32 %x, 1
+    %b = add i32 %y, 2
+    %c = add i32 %a, %b
+    %d = add i32 %c, 3
+    ret void
+  }
+...
+---
+name: test_spectral
+tracksRegLiveness: true
+body: |
+  bb.0.entry:
+    liveins: $x0, $x1
+    
+    %0:gpr32 = COPY $w0
+    %1:gpr32 = COPY $w1
+    %2:gpr32 = ADDWri %0, 1
+    %3:gpr32 = ADDWri %1, 2
+    %4:gpr32 = ADDWrr %2, %3
+    %5:gpr32 = ADDWri %4, 3
+    $w0 = COPY %5
+    RET_ReallyLR implicit $w0
+
+# CHECK: spectral coloring succeeded
+# CHECK-NOT: spill
+
+---
+# Additional test: chain interference requiring 3 colors
+name: test_spectral_chain
+tracksRegLiveness: true
+body: |
+  bb.0.entry:
+    %0:gpr32 = IMPLICIT_DEF
+    %1:gpr32 = IMPLICIT_DEF
+    %2:gpr32 = IMPLICIT_DEF
+    %3:gpr32 = IMPLICIT_DEF
+    %4:gpr32 = IMPLICIT_DEF
+    
+    ; Chain: 0-1-2-3-4, all interfere
+    %1 = ADDWrr %0, %1
+    %2 = ADDWrr %1, %2
+    %3 = ADDWrr %2, %3
+    %4 = ADDWrr %3, %4
+    
+    $w0 = COPY %4
+    RET_ReallyLR implicit $w0
+
+# CHECK: 3 physical registers allocated
+# CHECK: spill count 0
+
