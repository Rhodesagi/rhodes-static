import * as THREE from 'three';
import { InputManager } from './input.js';
import { World } from './world.js';
import { Player } from './player.js';
import { ProjectileManager } from './projectile.js';
import { AudioManager } from './audio.js';

class Game {
    constructor() {
        this.canvas = document.getElementById('game-canvas');
        this.renderer = new THREE.WebGLRenderer({ 
            canvas: this.canvas, 
            antialias: true,
            alpha: false
        });
        this.renderer.setSize(window.innerWidth, window.innerHeight);
        this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        this.renderer.shadowMap.enabled = true;
        this.renderer.shadowMap.type = THREE.PCFSoftShadowMap;
        
        this.input = new InputManager();
        this.audio = new AudioManager();
        this.world = new World();
        this.projectiles = new ProjectileManager(this.world);
        
        // Create players with distinct key mappings
        this.player1 = new Player(1, 
            new THREE.Vector3(-8, 1.6, 0), 
            this.input,
            this.input.player1Keys,
            this.world,
            this.projectiles,
            this.audio
        );
        
        this.player2 = new Player(2, 
            new THREE.Vector3(8, 1.6, 0), 
            this.input,
            this.input.player2Keys,
            this.world,
            this.projectiles,
            this.audio
        );
        
        this.player1.setOpponent(this.player2);
        this.player2.setOpponent(this.player1);
        
        // Register players with projectile manager for hit detection
        this.projectiles.registerPlayer(this.player1);
        this.projectiles.registerPlayer(this.player2);
        
        this.isRunning = false;
        this.clock = new THREE.Clock();
        
        this.setupViewportDivider();
        this.setupEventListeners();
        
        // Start render loop immediately (game logic waits for space)
        this.animate();
        
        console.log('Game initialized. Press SPACE to start.');
    }
    
    setupViewportDivider() {
        const divider = document.createElement('div');
        divider.className = 'viewport-divider';
        document.getElementById('ui-overlay').appendChild(divider);
    }
    
    setupEventListeners() {
        window.addEventListener('resize', () => this.onResize());
        
        // Space to start - capture at window level with preventDefault
        const startHandler = (e) => {
            if ((e.code === 'Space' || e.key === ' ' || e.keyCode === 32) && !this.isRunning) {
                e.preventDefault();
                e.stopPropagation();
                this.startGame();
            }
        };
        
        // Use capture phase to catch event early
        window.addEventListener('keydown', startHandler, true);
        
        // Click to start as fallback
        const instructions = document.getElementById('instructions');
        if (instructions) {
            instructions.addEventListener('click', (e) => {
                e.preventDefault();
                this.startGame();
            });
            instructions.style.cursor = 'pointer';
        }
        
        // Also allow Enter key to start for accessibility
        window.addEventListener('keydown', (e) => {
            if (e.code === 'Enter' && !this.isRunning && !e.repeat) {
                e.preventDefault();
                this.startGame();
            }
        }, true);
    }
    
    startGame() {
        if (this.isRunning) return;
        this.isRunning = true;
        
        const instructions = document.getElementById('instructions');
        if (instructions) {
            instructions.classList.add('hidden');
            instructions.style.display = 'none';
        }
        
        const startText = document.getElementById('start-text');
        if (startText) {
            startText.style.display = 'none';
        }
        
        // Resume audio context
        this.audio.resume();
        
        console.log('Game started!');
    }
    
    onResize() {
        this.renderer.setSize(window.innerWidth, window.innerHeight);
    }
    
    animate() {
        requestAnimationFrame(() => this.animate());
        
        const deltaTime = Math.min(this.clock.getDelta(), 0.1);
        
        if (this.isRunning) {
            this.update(deltaTime);
        }
        
        // Always render - show world even before game starts
        this.render();
    }
    
    update(deltaTime) {
        this.input.update();
        this.player1.update(deltaTime);
        this.player2.update(deltaTime);
        this.projectiles.update(deltaTime);
    }
    
    render() {
        const width = this.canvas.clientWidth;
        const height = this.canvas.clientHeight;
        
        // Clear the entire canvas first
        this.renderer.setScissorTest(false);
        this.renderer.setClearColor(0x87CEEB, 1); // Sky blue clear
        this.renderer.clear();
        
        // Render Player 1 viewport (left half)
        this.renderer.setScissorTest(true);
        this.renderer.setScissor(0, 0, width / 2, height);
        this.renderer.setViewport(0, 0, width / 2, height);
        
        // Hide P2's weapon, show P1's weapon for P1's view
        this.player2.hideWeapon();
        this.player1.showWeapon();
        
        this.renderer.render(this.world.scene, this.player1.camera);
        
        // Render Player 2 viewport (right half)
        this.renderer.setScissor(width / 2, 0, width / 2, height);
        this.viewportWidth = width / 2;
        this.viewportHeight = height;
        this.renderer.setViewport(width / 2, 0, width / 2, height);
        
        // Hide P1's weapon, show P2's weapon for P2's view
        this.player1.hideWeapon();
        this.player2.showWeapon();
        
        this.renderer.render(this.world.scene, this.player2.camera);
        
        // Restore both weapons for next frame's first pass
        this.player1.showWeapon();
        this.player2.hideWeapon();
    }
}

// Start immediately - DOM is already ready for module scripts
new Game();
