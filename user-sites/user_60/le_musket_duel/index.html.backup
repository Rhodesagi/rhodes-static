<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Le Musket Duel</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100%; height: 100%; overflow: hidden; background: #000; font-family: 'Georgia', serif; }
        #game-container { position: relative; width: 100%; height: 100%; }
        #game-canvas { display: block; width: 100%; height: 100%; background: #87CEEB; }
        #ui-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
        #instructions { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: #d4c4a8; background: rgba(20, 15, 10, 0.95); padding: 40px 60px; border: 3px solid #8b7355; display: flex; gap: 60px; align-items: center; pointer-events: auto; cursor: pointer; z-index: 100; }
        #instructions.hidden { display: none !important; }
        .player-keys { text-align: left; }
        .player-keys h3 { color: #c9a86c; margin-bottom: 10px; font-size: 14px; letter-spacing: 2px; }
        .player-keys p { font-size: 12px; color: #a09080; margin: 4px 0; }
        .title h1 { font-size: 32px; color: #c9a86c; letter-spacing: 4px; margin-bottom: 10px; text-shadow: 2px 2px 4px rgba(0,0,0,0.8); }
        .title p { color: #8b7355; font-size: 14px; font-style: italic; }
        #start-text { margin-top: 20px; color: #fff; font-weight: bold; animation: pulse 1.5s infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
        .viewport-divider { position: absolute; left: 50%; top: 0; width: 2px; height: 100%; background: linear-gradient(to bottom, transparent 0%, rgba(139, 115, 85, 0.5) 20%, rgba(139, 115, 85, 0.5) 80%, transparent 100%); pointer-events: none; }
        .hit-flash { position: absolute; top: 0; left: 0; width: 50%; height: 100%; background: rgba(255, 0, 0, 0.4); pointer-events: none; opacity: 0; transition: opacity 0.1s; }
        .hit-flash.active { opacity: 1; }
        .hit-flash.right { left: 50%; }
    </style>
</head>
<body>
    <div id="game-container">
        <canvas id="game-canvas"></canvas>
        <div id="ui-overlay">
            <div id="instructions">
                <div class="player-keys left">
                    <h3>PLAYER 1</h3>
                    <p>WASD - Move | Q/E - Lean</p>
                    <p>Shift - Iron Sights | F - Fire | R - Reload</p>
                </div>
                <div class="title">
                    <h1>LE MUSKET DUEL</h1>
                    <p>No crosshairs. Iron sights only. Skill prevails.</p>
                    <p id="start-text">CLICK HERE to Start</p>
                </div>
                <div class="player-keys right">
                    <h3>PLAYER 2</h3>
                    <p>Arrows - Move | O/P - Lean</p>
                    <p>Enter - Iron Sights | L - Fire | K - Reload</p>
                </div>
            </div>
        </div>
    </div>

    <script type="importmap">
    {
        "imports": {
            "three": "https://unpkg.com/three@0.160.0/build/three.module.js?cachebust=2"
        }
    }
    </script>

    <script type="module">
        import * as THREE from 'three';

        // ===== AUDIO SYSTEM =====
        class AudioManager {
            constructor() {
                this.ctx = null;
                this.enabled = false;
            }
            
            resume() {
                if (!this.ctx) {
                    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
                }
                if (this.ctx.state === 'suspended') {
                    this.ctx.resume();
                }
                this.enabled = true;
            }
            
            playFire() {
                if (!this.ctx) return;
                const t = this.ctx.currentTime;
                const buffer = this.ctx.createBuffer(1, this.ctx.sampleRate * 0.8, this.ctx.sampleRate);
                const data = buffer.getChannelData(0);
                for (let i = 0; i < buffer.length; i++) {
                    data[i] = (Math.random() * 2 - 1) * Math.exp(-i / (this.ctx.sampleRate * 0.3));
                }
                const noise = this.ctx.createBufferSource();
                noise.buffer = buffer;
                const filter = this.ctx.createBiquadFilter();
                filter.type = 'lowpass';
                filter.frequency.setValueAtTime(2000, t);
                filter.frequency.exponentialRampToValueAtTime(100, t + 0.5);
                const gain = this.ctx.createGain();
                gain.gain.setValueAtTime(1.2, t);
                gain.gain.exponentialRampToValueAtTime(0.01, t + 0.8);
                noise.connect(filter);
                filter.connect(gain);
                gain.connect(this.ctx.destination);
                noise.start();
            }
            
            playClick() {
                if (!this.ctx) return;
                const t = this.ctx.currentTime;
                const osc = this.ctx.createOscillator();
                osc.type = 'square';
                osc.frequency.setValueAtTime(800, t);
                const gain = this.ctx.createGain();
                gain.gain.setValueAtTime(0.3, t);
                gain.gain.exponentialRampToValueAtTime(0.01, t + 0.1);
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.start();
                osc.stop(t + 0.1);
            }
            
            playRam() {
                if (!this.ctx) return;
                const t = this.ctx.currentTime;
                const osc = this.ctx.createOscillator();
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(150, t);
                const gain = this.ctx.createGain();
                gain.gain.setValueAtTime(0.2, t);
                gain.gain.exponentialRampToValueAtTime(0.01, t + 0.15);
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.start();
                osc.stop(t + 0.15);
            }
        }

        // ===== INPUT SYSTEM =====
        class InputManager {
            constructor() {
                this.keys = {};
                this.player1Keys = {
                    forward: 'KeyW', backward: 'KeyS', left: 'KeyA', right: 'KeyD',
                    leanLeft: 'KeyQ', leanRight: 'KeyE',
                    ironSights: 'ShiftLeft', fire: 'KeyF', reload: 'KeyR'
                };
                this.player2Keys = {
                    forward: 'ArrowUp', backward: 'ArrowDown', left: 'ArrowLeft', right: 'ArrowRight',
                    leanLeft: 'KeyO', leanRight: 'KeyP',
                    ironSights: 'Enter', fire: 'KeyL', reload: 'KeyK'
                };
                
                window.addEventListener('keydown', (e) => {
                    this.keys[e.code] = true;
                    const gameKeys = ['ArrowUp','ArrowDown','ArrowLeft','ArrowRight','Space','ShiftLeft','ShiftRight','Enter','KeyW','KeyA','KeyS','KeyD','KeyQ','KeyE','KeyF','KeyR','KeyK','KeyL','KeyO','KeyP'];
                    if (gameKeys.includes(e.code)) e.preventDefault();
                }, true);
                
                window.addEventListener('keyup', (e) => {
                    this.keys[e.code] = false;
                }, true);
            }
            
            isPressed(code) { return !!this.keys[code]; }
            
            getInput(keyMap) {
                return {
                    moveForward: this.isPressed(keyMap.forward),
                    moveBackward: this.isPressed(keyMap.backward),
                    moveLeft: this.isPressed(keyMap.left),
                    moveRight: this.isPressed(keyMap.right),
                    leanLeft: this.isPressed(keyMap.leanLeft),
                    leanRight: this.isPressed(keyMap.leanRight),
                    ironSights: this.isPressed(keyMap.ironSights),
                    fire: this.isPressed(keyMap.fire),
                    reload: this.isPressed(keyMap.reload)
                };
            }
        }

        // ===== MUSKET CLASS =====
        class Musket {
            constructor(playerId, camera, world, projectiles, audio) {
                this.playerId = playerId;
                this.camera = camera;
                this.world = world;
                this.projectiles = projectiles;
                this.audio = audio;
                this.state = 'ready';
                this.reloadProgress = 0;
                this.isReloading = false;
                this.ramrodExtension = 0;
                this.flashOpacity = 0;
                
                this.createMesh();
                this.shoulderedPos = new THREE.Vector3(0.15, -0.15, 0.35);
                this.aimedPos = new THREE.Vector3(0.02, -0.02, 0.18);
                this.reloadPos = new THREE.Vector3(0.3, -0.5, 0.4);
                this.currentPos = this.shoulderedPos.clone();
                this.targetPos = this.shoulderedPos.clone();
                
                this.camera.add(this.mesh);
            }
            
            createMesh() {
                this.mesh = new THREE.Group();
                
                const woodMat = new THREE.MeshStandardMaterial({ color: 0x5a3a2a, roughness: 0.6 });
                const metalMat = new THREE.MeshStandardMaterial({ color: 0x888888, roughness: 0.3, metalness: 0.8 });
                const darkMetalMat = new THREE.MeshStandardMaterial({ color: 0x333333, roughness: 0.4, metalness: 0.6 });
                
                // Stock
                const stockGeo = new THREE.BoxGeometry(0.05, 0.06, 0.7);
                this.stock = new THREE.Mesh(stockGeo, woodMat);
                this.stock.position.set(0, 0, 0.05);
                this.mesh.add(this.stock);
                
                // Barrel
                const barrelGeo = new THREE.CylinderGeometry(0.02, 0.02, 0.8, 8);
                this.barrel = new THREE.Mesh(barrelGeo, metalMat);
                this.barrel.rotation.x = Math.PI / 2;
                this.barrel.position.set(0, 0.04, 0.1);
                this.mesh.add(this.barrel);
                
                // Lock plate
                const lockGeo = new THREE.BoxGeometry(0.015, 0.03, 0.1);
                this.lockPlate = new THREE.Mesh(lockGeo, darkMetalMat);
                this.lockPlate.position.set(0.035, 0.015, 0.02);
                this.mesh.add(this.lockPlate);
                
                // Frizzen (hinged cover)
                this.frizzen = new THREE.Group();
                this.frizzen.position.set(0.035, 0.015, 0.08);
                const frizzenGeo = new THREE.BoxGeometry(0.015, 0.04, 0.03);
                const frizzenMesh = new THREE.Mesh(frizzenGeo, darkMetalMat);
                frizzenMesh.position.set(0, 0.015, 0.015);
                this.frizzen.add(frizzenMesh);
                this.mesh.add(this.frizzen);
                
                // Hammer
                this.hammer = new THREE.Group();
                this.hammer.position.set(0.035, 0.015, 0.04);
                const hammerGeo = new THREE.BoxGeometry(0.01, 0.04, 0.015);
                const hammerMesh = new THREE.Mesh(hammerGeo, darkMetalMat);
                hammerMesh.position.set(0, 0.02, 0);
                this.hammer.add(hammerMesh);
                this.mesh.add(this.hammer);
                
                // Pan flash
                const flashGeo = new THREE.SphereGeometry(0.015, 6, 6);
                const flashMat = new THREE.MeshBasicMaterial({ color: 0xffaa00, transparent: true, opacity: 0 });
                this.panFlash = new THREE.Mesh(flashGeo, flashMat);
                this.panFlash.position.set(0.035, 0.03, 0.075);
                this.mesh.add(this.panFlash);
                
                // Muzzle flash
                const muzzleGeo = new THREE.ConeGeometry(0.025, 0.15, 6);
                const muzzleMat = new THREE.MeshBasicMaterial({ color: 0xffffaa, transparent: true, opacity: 0 });
                this.muzzleFlash = new THREE.Mesh(muzzleGeo, muzzleMat);
                this.muzzleFlash.position.set(0, 0.04, 0.55);
                this.muzzleFlash.rotation.x = Math.PI / 2;
                this.mesh.add(this.muzzleFlash);
                
                // Ramrod
                this.ramrod = new THREE.Group();
                const rodGeo = new THREE.CylinderGeometry(0.002, 0.002, 0.85, 4);
                const rodMesh = new THREE.Mesh(rodGeo, woodMat);
                rodMesh.rotation.x = Math.PI / 2;
                this.ramrod.add(rodMesh);
                this.ramrod.position.set(0, -0.025, 0.1);
                this.mesh.add(this.ramrod);
                
                // Sights
                const rearSightGeo = new THREE.BoxGeometry(0.008, 0.012, 0.003);
                const rearSight = new THREE.Mesh(rearSightGeo, darkMetalMat);
                rearSight.position.set(0, 0.055, -0.2);
                this.mesh.add(rearSight);
                
                const frontSightGeo = new THREE.CylinderGeometry(0.0015, 0.0015, 0.012, 4);
                const frontSight = new THREE.Mesh(frontSightGeo, darkMetalMat);
                frontSight.position.set(0, 0.06, 0.5);
                this.mesh.add(frontSight);
                
                this.mesh.position.copy(this.shoulderedPos);
            }
            
            update(dt) {
                // Flash fade
                if (this.panFlash.material.opacity > 0) {
                    this.panFlash.material.opacity -= dt * 8;
                    if (this.panFlash.material.opacity < 0) this.panFlash.material.opacity = 0;
                }
                if (this.muzzleFlash.material.opacity > 0) {
                    this.muzzleFlash.material.opacity -= dt * 12;
                    if (this.muzzleFlash.material.opacity < 0) this.muzzleFlash.material.opacity = 0;
                }
                
                // Reload progress
                if (this.isReloading) {
                    this.reloadProgress += dt;
                    const stageTime = 0.6;
                    const stage = Math.floor(this.reloadProgress / stageTime);
                    const stageProgress = (this.reloadProgress % stageTime) / stageTime;
                    
                    // Animate ramrod during stages 3-5
                    if (stage >= 3 && stage <= 5) {
                        this.ramrodExtension = Math.sin(stageProgress * Math.PI);
                    } else {
                        this.ramrodExtension = Math.max(0, this.ramrodExtension - dt * 2);
                    }
                    
                    // Frizzen open during middle stages
                    this.frizzen.rotation.x = (stage >= 2 && stage <= 6) ? Math.PI / 4 : 0;
                    
                    // Hammer position
                    if (stage === 0) this.hammer.rotation.x = -Math.PI / 4;
                    else if (stage >= 7) this.hammer.rotation.x = -Math.PI / 2;
                    
                    // Position animation
                    if (stage < 2) this.targetPos = this.reloadPos;
                    else if (stage > 7) this.targetPos = this.shoulderedPos;
                    
                    // Play sounds
                    if (Math.abs(this.reloadProgress - 3.5 * stageTime) < dt) this.audio.playRam();
                    if (Math.abs(this.reloadProgress - 4.5 * stageTime) < dt) this.audio.playRam();
                    if (Math.abs(this.reloadProgress - 5.5 * stageTime) < dt) this.audio.playRam();
                    
                    if (this.reloadProgress > 5.4) {
                        this.isReloading = false;
                        this.state = 'ready';
                        this.ramrodExtension = 0;
                        this.targetPos = this.shoulderedPos;
                    }
                }
                
                // Smooth position
                this.mesh.position.lerp(this.targetPos, dt * 10);
                
                // Ramrod animation
                const rodExtend = this.ramrodExtension * 0.35;
                this.ramrod.position.z = 0.1 + rodExtend;
                this.ramrod.rotation.x = this.ramrodExtension * Math.PI * 0.6;
            }
            
            fire() {
                if (this.state !== 'ready' || this.isReloading) {
                    this.audio.playClick();
                    return false;
                }
                
                // Flintlock sequence
                this.hammer.rotation.x = 0;
                this.frizzen.rotation.x = Math.PI / 4;
                this.panFlash.material.opacity = 1;
                
                setTimeout(() => {
                    this.muzzleFlash.material.opacity = 1;
                    this.mesh.rotation.x += 0.12;
                    setTimeout(() => this.mesh.rotation.x -= 0.12, 100);
                    this.audio.playFire();
                    
                    // Spawn projectile
                    const barrelTip = new THREE.Vector3(0, 0.04, 0.55);
                    barrelTip.applyMatrix4(this.mesh.matrixWorld);
                    const direction = new THREE.Vector3(0, 0, 1);
                    direction.applyQuaternion(this.camera.quaternion);
                    this.projectiles.spawn(barrelTip, direction, 120, this.playerId);
                    
                    this.state = 'empty';
                    this.hammer.rotation.x = 0;
                }, 400);
                
                return true;
            }
            
            startReload() {
                if (this.isReloading || this.state === 'ready') return false;
                this.isReloading = true;
                this.reloadProgress = 0;
                this.targetPos = this.reloadPos;
                return true;
            }
            
            setIronSights(active) {
                if (!this.isReloading) {
                    this.targetPos = active ? this.aimedPos : this.shoulderedPos;
                }
            }
            
            reset() {
                this.state = 'ready';
                this.isReloading = false;
                this.reloadProgress = 0;
                this.targetPos = this.shoulderedPos;
                this.frizzen.rotation.x = 0;
                this.hammer.rotation.x = -Math.PI / 2;
            }
            
            hide() { this.mesh.visible = false; }
            show() { this.mesh.visible = true; }
        }

        // ===== PROJECTILE CLASS =====
        class Projectile {
            constructor(start, direction, speed, ownerId, world) {
                this.ownerId = ownerId;
                this.world = world;
                this.position = start.clone();
                this.velocity = direction.clone().multiplyScalar(speed);
                this.active = true;
                
                const geo = new THREE.SphereGeometry(0.008, 4, 4);
                const mat = new THREE.MeshBasicMaterial({ color: 0x888888 });
                this.mesh = new THREE.Mesh(geo, mat);
                this.mesh.position.copy(this.position);
                world.scene.add(this.mesh);
            }
            
            update(dt) {
                if (!this.active) return false;
                
                this.velocity.y -= 9.8 * dt;
                this.position.add(this.velocity.clone().multiplyScalar(dt));
                this.mesh.position.copy(this.position);
                
                if (this.position.y <= 0 || this.position.y > 50) {
                    this.destroy();
                    return false;
                }
                return true;
            }
            
            checkHit(player) {
                if (!this.active || !player || !player.position || player.id === this.ownerId || player.isDead) return false;
                const dx = this.position.x - player.position.x;
                const dz = this.position.z - player.position.z;
                const dy = this.position.y - player.position.y;
                if (dx*dx + dz*dz + dy*dy < 0.16) {
                    player.takeDamage(100);
                    this.destroy();
                    return true;
                }
                return false;
            }
            
            destroy() {
                this.active = false;
                this.world.scene.remove(this.mesh);
            }
        }

        class ProjectileManager {
            constructor(world) { this.world = world; this.projectiles = []; this.players = []; }
            registerPlayer(p) { this.players.push(p); }
            spawn(start, dir, speed, ownerId) {
                this.projectiles.push(new Projectile(start, dir, speed, ownerId, this.world));
            }
            update(dt) {
                for (let i = this.projectiles.length - 1; i >= 0; i--) {
                    const p = this.projectiles[i];
                    if (!p.update(dt)) {
                        this.projectiles.splice(i, 1);
                        continue;
                    }
                    for (const player of this.players) {
                        if (p.checkHit(player)) break;
                    }
                }
            }
        }

        // ===== WORLD CLASS =====
        class World {
            constructor() {
                this.scene = new THREE.Scene();
                this.scene.background = new THREE.Color(0x87CEEB);
                this.scene.fog = new THREE.Fog(0x87CEEB, 25, 70);
                
                const ambient = new THREE.AmbientLight(0xffffff, 0.5);
                this.scene.add(ambient);
                
                const sun = new THREE.DirectionalLight(0xffffff, 0.9);
                sun.position.set(15, 25, 10);
                sun.castShadow = true;
                sun.shadow.mapSize.set(2048, 2048);
                sun.shadow.camera.near = 0.5;
                sun.shadow.camera.far = 60;
                sun.shadow.camera.left = -25;
                sun.shadow.camera.right = 25;
                sun.shadow.camera.top = 25;
                sun.shadow.camera.bottom = -25;
                this.scene.add(sun);
                
                const hemi = new THREE.HemisphereLight(0xffffff, 0x6b5a4a, 0.3);
                this.scene.add(hemi);
                
                // Ground
                const groundGeo = new THREE.PlaneGeometry(50, 50, 30, 30);
                const pos = groundGeo.attributes.position;
                for (let i = 0; i < pos.count; i++) {
                    const x = pos.getX(i), y = pos.getY(i);
                    pos.setZ(i, Math.sin(x * 0.25) * 0.08 + Math.cos(y * 0.25) * 0.08);
                }
                groundGeo.computeVertexNormals();
                
                const groundMat = new THREE.MeshStandardMaterial({ color: 0x5a4a3a, roughness: 0.9 });
                this.ground = new THREE.Mesh(groundGeo, groundMat);
                this.ground.rotation.x = -Math.PI / 2;
                this.ground.receiveShadow = true;
                this.scene.add(this.ground);
                
                // Walls
                const wallMat = new THREE.MeshStandardMaterial({ color: 0x6b5a4a, roughness: 0.8 });
                this.walls = [];
                const wallPos = [
                    { x: -8, z: -8, w: 4, d: 0.5 },
                    { x: 8, z: 8, w: 4, d: 0.5 },
                    { x: -8, z: 8, w: 0.5, d: 4 },
                    { x: 8, z: -8, w: 0.5, d: 4 }
                ];
                
                for (const wp of wallPos) {
                    const geo = new THREE.BoxGeometry(wp.w, 1.2, wp.d);
                    const wall = new THREE.Mesh(geo, wallMat);
                    wall.position.set(wp.x, 0.6, wp.z);
                    wall.castShadow = true;
                    wall.receiveShadow = true;
                    this.scene.add(wall);
                    this.walls.push(wall);
                }
                
                // Trees
                const trunkMat = new THREE.MeshStandardMaterial({ color: 0x4a3a2a });
                const leafMat = new THREE.MeshStandardMaterial({ color: 0x2d4a2d });
                const treePos = [[-15, -15], [15, 15], [-15, 15], [15, -15]];
                for (const [x, z] of treePos) {
                    const trunk = new THREE.Mesh(new THREE.CylinderGeometry(0.25, 0.35, 2, 6), trunkMat);
                    trunk.position.set(x, 1, z);
                    trunk.castShadow = true;
                    this.scene.add(trunk);
                    
                    const leaves = new THREE.Mesh(new THREE.ConeGeometry(1.8, 3.5, 6), leafMat);
                    leaves.position.set(x, 2.75, z);
                    leaves.castShadow = true;
                    this.scene.add(leaves);
                }
            }
        }

        // ===== PLAYER CLASS =====
        class Player {
            constructor(id, startPos, input, keyMap, world, projectiles, audio) {
                this.id = id;
                this.input = input;
                this.keyMap = keyMap;
                this.world = world;
                this.projectiles = projectiles;
                this.audio = audio;
                
                this.health = 100;
                this.maxHealth = 100;
                this.isDead = false;
                this.respawnTimer = 0;
                
                this.position = startPos.clone();
                this.rotation = new THREE.Euler(0, id === 1 ? Math.PI / 2 : -Math.PI / 2, 0);
                this.velocity = new THREE.Vector3();
                
                this.camera = new THREE.PerspectiveCamera(60, 0.5, 0.1, 1000);
                this.camera.position.copy(startPos);
                this.camera.rotation.order = 'YXZ';
                this.camera.rotation.y = this.rotation.y + Math.PI;
                
                this.leanAmount = 0;
                this.ironSightsTransition = 0;
                this.inIronSights = false;
                this.prevFire = false;
                this.prevReload = false;
                
                this.createBody();
                this.musket = new Musket(id, this.camera, world, projectiles, audio);
                
                this.opponent = null;
            }
            
            createBody() {
                const bodyMat = new THREE.MeshStandardMaterial({ color: this.id === 1 ? 0x4a5a8a : 0x8a4a4a, roughness: 0.7 });
                this.mesh = new THREE.Mesh(new THREE.CylinderGeometry(0.28, 0.28, 1.65, 8), bodyMat);
                this.mesh.position.set(this.position.x, 0.825, this.position.z);
                this.mesh.castShadow = true;
                this.world.scene.add(this.mesh);
                
                const headMat = new THREE.MeshStandardMaterial({ color: 0xd0b090 });
                this.head = new THREE.Mesh(new THREE.SphereGeometry(0.18, 8, 8), headMat);
                this.head.position.y = 0.9;
                this.mesh.add(this.head);
            }
            
            setOpponent(o) { this.opponent = o; }
            
            update(dt) {
                if (this.isDead) {
                    this.respawnTimer -= dt;
                    if (this.respawnTimer <= 0) this.respawn();
                    return;
                }
                
                if (!this.opponent || !this.opponent.position) return;
                
                const input = this.input.getInput(this.keyMap);
                
                // Movement
                const moveDir = new THREE.Vector3();
                if (input.moveForward) moveDir.z -= 1;
                if (input.moveBackward) moveDir.z += 1;
                if (input.moveLeft) moveDir.x -= 1;
                if (input.moveRight) moveDir.x += 1;
                
                if (moveDir.length() > 0) {
                    moveDir.normalize().applyAxisAngle(new THREE.Vector3(0, 1, 0), this.rotation.y);
                    this.velocity.x = moveDir.x * 4;
                    this.velocity.z = moveDir.z * 4;
                } else {
                    this.velocity.multiplyScalar(0.85);
                }
                
                this.position.x += this.velocity.x * dt;
                this.position.z += this.velocity.z * dt;
                this.position.x = Math.max(-22, Math.min(22, this.position.x));
                this.position.z = Math.max(-22, Math.min(22, this.position.z));
                
                // Lean
                const targetLean = (input.leanLeft ? -0.25 : 0) + (input.leanRight ? 0.25 : 0);
                this.leanAmount += (targetLean - this.leanAmount) * 8 * dt;
                
                // Iron sights
                const targetIron = input.ironSights ? 1 : 0;
                this.ironSightsTransition += (targetIron - this.ironSightsTransition) * 6 * dt;
                this.inIronSights = this.ironSightsTransition > 0.3;
                this.musket.setIronSights(this.inIronSights);
                
                // Fire
                if (input.fire && !this.prevFire) {
                    this.musket.fire();
                }
                this.prevFire = input.fire;
                
                // Reload
                if (input.reload && !this.prevReload) {
                    this.musket.startReload();
                }
                this.prevReload = input.reload;
                
                // Auto-rotate toward opponent
                const dir = new THREE.Vector3().subVectors(this.opponent.position, this.position).normalize();
                const targetAngle = Math.atan2(dir.x, dir.z) + Math.PI;
                let diff = targetAngle - this.rotation.y;
                while (diff > Math.PI) diff -= Math.PI * 2;
                while (diff < -Math.PI) diff += Math.PI * 2;
                this.rotation.y += diff * 2.5 * dt;
                
                // Update camera
                const camPos = this.position.clone();
                camPos.y = 1.6;
                const leanOffset = new THREE.Vector3(this.leanAmount, 0, 0);
                leanOffset.applyAxisAngle(new THREE.Vector3(0, 1, 0), this.rotation.y);
                camPos.add(leanOffset);
                
                // Iron sights offset
                if (this.ironSightsTransition > 0.01) {
                    const sightOffset = new THREE.Vector3(0.12, -0.04, 0.2);
                    sightOffset.multiplyScalar(this.ironSightsTransition);
                    sightOffset.applyAxisAngle(new THREE.Vector3(0, 1, 0), this.rotation.y);
                    camPos.add(sightOffset);
                }
                
                this.camera.position.copy(camPos);
                this.camera.rotation.y = this.rotation.y + Math.PI;
                this.camera.rotation.z = -this.leanAmount * 0.3 * (this.inIronSights ? 0 : 1);
                
                // Update body mesh
                this.mesh.position.x = this.position.x;
                this.mesh.position.z = this.position.z;
                this.mesh.rotation.y = this.rotation.y;
                
                this.musket.update(dt);
            }
            
            takeDamage(amt) {
                if (this.isDead) return;
                this.health -= amt;
                
                // Hit flash
                const flashId = `hit-flash-${this.id}`;
                let flash = document.getElementById(flashId);
                if (!flash) {
                    flash = document.createElement('div');
                    flash.id = flashId;
                    flash.className = `hit-flash${this.id === 2 ? ' right' : ''}`;
                    document.getElementById('ui-overlay').appendChild(flash);
                }
                flash.classList.add('active');
                setTimeout(() => flash.classList.remove('active'), 150);
                
                if (this.health <= 0) {
                    this.die();
                }
            }
            
            die() {
                this.isDead = true;
                this.respawnTimer = 2;
                this.mesh.visible = false;
            }
            
            respawn() {
                this.isDead = false;
                this.health = this.maxHealth;
                this.mesh.visible = true;
                this.position.set(
                    this.id === 1 ? -8 : 8,
                    1.6,
                    (Math.random() - 0.5) * 4
                );
                this.rotation.y = this.id === 1 ? Math.PI / 2 : -Math.PI / 2;
                this.velocity.set(0, 0, 0);
                this.leanAmount = 0;
                this.ironSightsTransition = 0;
                this.inIronSights = false;
                this.musket.reset();
            }
            
            hideWeapon() { this.musket.hide(); }
            showWeapon() { this.musket.show(); }
        }

        // ===== MAIN GAME =====
        class Game {
            constructor() {
                this.canvas = document.getElementById('game-canvas');
                this.renderer = new THREE.WebGLRenderer({ canvas: this.canvas, antialias: true });
                this.renderer.setSize(window.innerWidth, window.innerHeight);
                this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
                this.renderer.shadowMap.enabled = true;
                this.renderer.shadowMap.type = THREE.PCFSoftShadowMap;
                
                this.input = new InputManager();
                this.audio = new AudioManager();
                this.world = new World();
                this.projectiles = new ProjectileManager(this.world);
                
                this.player1 = new Player(1, new THREE.Vector3(-8, 1.6, 0), this.input, this.input.player1Keys, this.world, this.projectiles, this.audio);
                this.player2 = new Player(2, new THREE.Vector3(8, 1.6, 0), this.input, this.input.player2Keys, this.world, this.projectiles, this.audio);
                
                this.player1.setOpponent(this.player2);
                this.player2.setOpponent(this.player1);
                this.projectiles.registerPlayer(this.player1);
                this.projectiles.registerPlayer(this.player2);
                
                this.clock = new THREE.Clock();
                this.isRunning = false;
                
                // Viewport divider
                const divider = document.createElement('div');
                divider.className = 'viewport-divider';
                document.getElementById('ui-overlay').appendChild(divider);
                
                // Start button
                const instructions = document.getElementById('instructions');
                instructions.addEventListener('click', () => this.start());
                
                // Keyboard start
                window.addEventListener('keydown', (e) => {
                    if ((e.code === 'Space' || e.code === 'Enter') && !this.isRunning) {
                        e.preventDefault();
                        this.start();
                    }
                }, true);
                
                window.addEventListener('resize', () => {
                    this.renderer.setSize(window.innerWidth, window.innerHeight);
                });
                
                this.animate();
                console.log('Game loaded. Click or press SPACE to start.');
            }
            
            start() {
                if (this.isRunning) return;
                this.isRunning = true;
                document.getElementById('instructions').classList.add('hidden');
                this.audio.resume();
                console.log('Game started!');
            }
            
            animate() {
                requestAnimationFrame(() => this.animate());
                
                const dt = Math.min(this.clock.getDelta(), 0.1);
                
                if (this.isRunning) {
                    this.player1.update(dt);
                    this.player2.update(dt);
                    this.projectiles.update(dt);
                }
                
                this.render();
            }
            
            render() {
                const w = this.canvas.clientWidth;
                const h = this.canvas.clientHeight;
                
                this.renderer.setScissorTest(false);
                this.renderer.setClearColor(0x87CEEB, 1);
                this.renderer.clear();
                
                // P1 view (left)
                this.renderer.setScissorTest(true);
                this.renderer.setScissor(0, 0, w / 2, h);
                this.renderer.setViewport(0, 0, w / 2, h);
                this.player2.hideWeapon();
                this.player1.showWeapon();
                this.renderer.render(this.world.scene, this.player1.camera);
                
                // P2 view (right)
                this.renderer.setScissor(w / 2, 0, w / 2, h);
                this.renderer.setViewport(w / 2, 0, w / 2, h);
                this.player1.hideWeapon();
                this.player2.showWeapon();
                this.renderer.render(this.world.scene, this.player2.camera);
                
                // Weapon visibility already handled per-viewport above
            }
        }

        // Start game when module loads
        try {
            new Game();
        } catch (e) {
            console.error('Game error:', e);
            document.body.innerHTML = '<div style="color:white;text-align:center;padding:50px;"><h2>Error</h2><p>' + e.message + '</p></div>';
        }
    </script>
</body>
</html>
