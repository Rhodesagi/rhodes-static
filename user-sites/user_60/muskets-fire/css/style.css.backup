* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    overflow: hidden;
    background: #000;
    font-family: 'Courier New', monospace;
}

#game-container {
    position: relative;
    width: 100vw;
    height: 100vh;
}

#split-screen {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    z-index: 10;
    pointer-events: none;
}

.viewport {
    flex: 1;
    border: 2px solid #333;
    position: relative;
    pointer-events: auto;
    cursor: crosshair;
    background: rgba(0,0,0,0.1);
}

.viewport:hover {
    border-color: #666;
}

.viewport.locked {
    border-color: #0a0;
}

.viewport.active::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border: 2px solid #fff;
    animation: pulse 2s infinite;
    pointer-events: none;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
}

.player-label {
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    color: #fff;
    font-size: 14px;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
    text-transform: uppercase;
    letter-spacing: 2px;
    pointer-events: none;
}

.controls-hint {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.7);
    font-size: 11px;
    text-align: center;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
    pointer-events: none;
    max-width: 90%;
}

#game-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
}

/* No HUD elements per requirements */
.no-hud {
    display: none !important;
}

/* Loading screen */
#loading {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    color: #fff;
    font-size: 18px;
}

.hidden {
    display: none !important;
}