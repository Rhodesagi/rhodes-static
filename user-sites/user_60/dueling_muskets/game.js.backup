// Dueling Muskets - Complete 2-Player FPS Game
// Three.js-based with iron sights, realistic reloading, and projectile physics

// ============================================
// GAME CONSTANTS
// ============================================
const MUSKET_BALL_SPEED = 200; // m/s scaled to world units
const MUSKET_BALL_DROP = 9.8; // gravity
const RELOAD_STEP_TIME = 0; // Manual advance with key press
const SMOKE_LIFETIME = 8.0; // seconds
const MAX_HEALTH = 100;
const ARENA_SIZE = 200;

// Reload state enumeration
const RELOAD_STATES = {
    READY: 0,
    HALF_COCK: 1,
    POWDER: 2,
    PATCH_BALL: 3,
    RAMROD: 4,
    FULL_COCK: 5,
    CAP: 6
};

const RELOAD_NAMES = [
    "READY TO FIRE",
    "HALF-COCK HAMMER (Press R/O)",
    "POUR POWDER (Press R/O)",
    "PATCH AND BALL (Press R/O)",
    "RAMROD: STROKE 1/3 (Press R/O)",
    "RAMROD: STROKE 2/3 (Press R/O)",
    "RAMROD: STROKE 3/3 (Press R/O)",
    "FULL COCK (Press R/O)",
    "PLACE CAP (Press R/O)"
];

// ============================================
// THREE.JS SETUP
// ============================================
const scene = new THREE.Scene();
scene.fog = new THREE.Fog(0xcccccc, 10, 150);
scene.background = new THREE.Color(0x87CEEB);

// Two renderers for split-screen
const renderer1 = new THREE.WebGLRenderer({ canvas: document.getElementById('canvas1'), antialias: true });
const renderer2 = new THREE.WebGLRenderer({ canvas: document.getElementById('canvas2'), antialias: true });
renderer1.setSize(window.innerWidth, window.innerHeight / 2);
renderer2.setSize(window.innerWidth, window.innerHeight / 2);
renderer1.shadowMap.enabled = true;
renderer2.shadowMap.enabled = true;

// ============================================
// SCENE OBJECTS - TERRAIN
// ============================================
// Ground
const groundGeo = new THREE.PlaneGeometry(ARENA_SIZE * 2, ARENA_SIZE * 2, 50, 50);
const groundMat = new THREE.MeshStandardMaterial({ 
    color: 0x3d5c3d,
    roughness: 0.9,
    metalness: 0.0
});
const ground = new THREE.Mesh(groundGeo, groundMat);
ground.rotation.x = -Math.PI / 2;
ground.receiveShadow = true;
scene.add(ground);

// Add some random terrain variation (low hills)
const positions = ground.geometry.attributes.position;
for (let i = 0; i < positions.count; i++) {
    const x = positions.getX(i);
    const y = positions.getY(i);
    const z = Math.sin(x * 0.05) * Math.cos(y * 0.05) * 2;
    positions.setZ(i, z);
}
ground.geometry.computeVertexNormals();

// Trees/obstacles
for (let i = 0; i < 20; i++) {
    const trunkGeo = new THREE.CylinderGeometry(0.5, 0.8, 6, 8);
    const trunkMat = new THREE.MeshStandardMaterial({ color: 0x4a3728 });
    const trunk = new THREE.Mesh(trunkGeo, trunkMat);
    
    const leavesGeo = new THREE.ConeGeometry(3, 8, 8);
    const leavesMat = new THREE.MeshStandardMaterial({ color: 0x2d4a2d });
    const leaves = new THREE.Mesh(leavesGeo, leavesMat);
    leaves.position.y = 7;
    
    const tree = new THREE.Group();
    tree.add(trunk);
    tree.add(leaves);
    
    const x = (Math.random() - 0.5) * ARENA_SIZE * 1.5;
    const z = (Math.random() - 0.5) * ARENA_SIZE * 1.5;
    
    // Keep center area clear for dueling
    if (Math.abs(x) > 20 || Math.abs(z) > 20) {
        tree.position.set(x, 3, z);
        trunk.castShadow = true;
        leaves.castShadow = true;
        scene.add(tree);
    }
}

// Lighting
const ambientLight = new THREE.AmbientLight(0x404040, 0.6);
scene.add(ambientLight);

const dirLight = new THREE.DirectionalLight(0xffffff, 1);
dirLight.position.set(50, 100, 50);
dirLight.castShadow = true;
dirLight.shadow.camera.left = -100;
dirLight.shadow.camera.right = 100;
dirLight.shadow.camera.top = 100;
dirLight.shadow.camera.bottom = -100;
dirLight.shadow.mapSize.width = 2048;
dirLight.shadow.mapSize.height = 2048;
scene.add(dirLight);

// ============================================
// MUSKET MODEL BUILDER
// ============================================
function createMusketModel() {
    const musket = new THREE.Group();
    
    // Main barrel
    const barrelGeo = new THREE.CylinderGeometry(0.08, 0.12, 4, 16);
    const barrelMat = new THREE.MeshStandardMaterial({ 
        color: 0x1a1a1a, 
        metalness: 0.7, 
        roughness: 0.3 
    });
    const barrel = new THREE.Mesh(barrelGeo, barrelMat);
    barrel.rotation.x = Math.PI / 2;
    barrel.position.z = 2;
    barrel.castShadow = true;
    musket.add(barrel);
    
    // Barrel bands
    for (let i = 0; i < 3; i++) {
        const bandGeo = new THREE.CylinderGeometry(0.13, 0.13, 0.15, 16);
        const bandMat = new THREE.MeshStandardMaterial({ 
            color: 0xb87333, 
            metalness: 0.8, 
            roughness: 0.2 
        });
        const band = new THREE.Mesh(bandGeo, bandMat);
        band.rotation.x = Math.PI / 2;
        band.position.z = 0.5 + i * 1.5;
        musket.add(band);
    }
    
    // Stock
    const stockGeo = new THREE.BoxGeometry(0.3, 0.4, 3);
    const stockMat = new THREE.MeshStandardMaterial({ 
        color: 0x4a3728,
        roughness: 0.8 
    });
    const stock = new THREE.Mesh(stockGeo, stockMat);
    stock.position.set(0, -0.2, -1.5);
    musket.add(stock);
    
    // Stock curve (butt)
    const buttGeo = new THREE.BoxGeometry(0.35, 0.5, 1);
    const butt = new THREE.Mesh(buttGeo, stockMat);
    butt.position.set(0, 0.1, -3);
    butt.rotation.x = -0.2;
    musket.add(butt);
    
    // Lock mechanism (firing mechanism)
    const lockGeo = new THREE.BoxGeometry(0.15, 0.3, 0.8);
    const lockMat = new THREE.MeshStandardMaterial({ 
        color: 0xb87333, 
        metalness: 0.8, 
        roughness: 0.2 
    });
    const lock = new THREE.Mesh(lockGeo, lockMat);
    lock.position.set(0.15, 0, 0);
    musket.add(lock);
    
    // Hammer
    const hammerGeo = new THREE.BoxGeometry(0.1, 0.4, 0.3);
    const hammer = new THREE.Mesh(hammerGeo, lockMat);
    hammer.position.set(0.18, 0.3, -0.3);
    hammer.rotation.x = 0.3;
    musket.add(hammer);
    
    // Trigger guard
    const triggerGuardGeo = new THREE.TorusGeometry(0.15, 0.02, 8, 16, Math.PI);
    const triggerGuard = new THREE.Mesh(triggerGuardGeo, lockMat);
    triggerGuard.position.set(0, -0.3, -1);
    triggerGuard.rotation.y = Math.PI / 2;
    musket.add(triggerGuard);
    
    // Trigger
    const triggerGeo = new THREE.BoxGeometry(0.02, 0.1, 0.05);
    const trigger = new THREE.Mesh(triggerGeo, lockMat);
    trigger.position.set(0, -0.25, -1);
    trigger.rotation.x = -0.3;
    musket.add(trigger);
    
    // Front sight (iron sight - post)
    const frontSightGeo = new THREE.BoxGeometry(0.02, 0.15, 0.02);
    const frontSight = new THREE.Mesh(frontSightGeo, lockMat);
    frontSight.position.set(0, 0.3, 3.9);
    musket.add(frontSight);
    
    // Rear sight (notch) - V shape approximation
    const rearSightBaseGeo = new THREE.BoxGeometry(0.1, 0.08, 0.05);
    const rearSight = new THREE.Mesh(rearSightBaseGeo, lockMat);
    rearSight.position.set(0, 0.25, 0);
    musket.add(rearSight);
    
    // Ramrod (stored under barrel)
    const ramrodGeo = new THREE.CylinderGeometry(0.03, 0.03, 3.5, 8);
    const ramrodMat = new THREE.MeshStandardMaterial({ 
        color: 0xc0c0c0, 
        metalness: 0.5, 
        roughness: 0.4 
    });
    const ramrod = new THREE.Mesh(ramrodGeo, ramrodMat);
    ramrod.rotation.x = Math.PI / 2;
    ramrod.position.set(0, -0.35, 1.5);
    musket.add(ramrod);
    
    // Ramrod thimbles (holders)
    for (let i = 0; i < 2; i++) {
        const thimbleGeo = new THREE.TorusGeometry(0.06, 0.02, 8, 16);
        const thimble = new THREE.Mesh(thimbleGeo, lockMat);
        thimble.rotation.x = Math.PI / 2;
        thimble.position.set(0, -0.35, 0.5 + i * 2);
        musket.add(thimble);
    }
    
    // Store references for animation
    musket.userData = {
        barrel: barrel,
        ramrod: ramrod,
        hammer: hammer,
        ramrodExtended: false,
        ramrodStroke: 0
    };
    
    return musket;
}

// ============================================
// PLAYER CLASS
// ============================================
class Player {
    constructor(id, startPos, startRot) {
        this.id = id;
        this.position = startPos.clone();
        this.rotation = startRot.clone(); // yaw, pitch
        this.velocity = new THREE.Vector3();
        this.health = MAX_HEALTH;
        this.alive = true;
        
        // Camera
        this.camera = new THREE.PerspectiveCamera(75, window.innerWidth / (window.innerHeight / 2), 0.1, 1000);
        this.camera.position.copy(this.position);
        this.updateCameraRotation();
        
        // Gun model (first person - attached to camera)
        this.gun = createMusketModel();
        this.camera.add(this.gun);
        this.gun.position.set(0.3, -0.4, -0.8);
        this.gun.rotation.y = -0.1;
        
        // Gun states
        this.aiming = false; // Iron sights raised
        this.fired = false; // Has fired and needs reload
        this.reloadState = RELOAD_STATES.READY;
        this.reloadProgress = 0;
        this.ramrodStrokes = 0;
        
        // Third-person model (what other player sees)
        this.body = this.createBodyModel();
        this.body.position.copy(this.position);
        scene.add(this.body);
        
        // Hitbox
        this.hitbox = new THREE.Box3(
            new THREE.Vector3(-0.3, 0, -0.3),
            new THREE.Vector3(0.3, 1.8, 0.3)
        );
    }
    
    createBodyModel() {
        const group = new THREE.Group();
        
        // Body
        const bodyGeo = new THREE.CylinderGeometry(0.25, 0.3, 1.4, 8);
        const bodyMat = new THREE.MeshStandardMaterial({ color: 0x2d3a2d });
        const body = new THREE.Mesh(bodyGeo, bodyMat);
        body.position.y = 0.7;
        body.castShadow = true;
        group.add(body);
        
        // Head
        const headGeo = new THREE.SphereGeometry(0.2, 16, 16);
        const headMat = new THREE.MeshStandardMaterial({ color: 0xd4a574 });
        const head = new THREE.Mesh(headGeo, headMat);
        head.position.y = 1.55;
        head.castShadow = true;
        group.add(head);
        
        // Hat
        const hatGeo = new THREE.CylinderGeometry(0.3, 0.3, 0.15, 16);
        const hatMat = new THREE.MeshStandardMaterial({ color: 0x1a1a1a });
        const hat = new THREE.Mesh(hatGeo, hatMat);
        hat.position.y = 1.7;
        group.add(hat);
        
        // Hat brim
        const brimGeo = new THREE.CylinderGeometry(0.4, 0.4, 0.02, 16);
        const brim = new THREE.Mesh(brimGeo, hatMat);
        brim.position.y = 1.62;
        group.add(brim);
        
        // Third-person musket
        const gun = createMusketModel();
        gun.scale.set(0.8, 0.8, 0.8);
        gun.position.set(0.3, 0.9, 0.4);
        gun.rotation.y = -0.3;
        gun.rotation.x = -0.2;
        group.add(gun);
        group.userData.gun = gun;
        
        return group;
    }
    
    updateCameraRotation() {
        const euler = new THREE.Euler(this.rotation.y, this.rotation.x, 0, 'YXZ');
        this.camera.quaternion.setFromEuler(euler);
    }
    
    move(dx, dz, dt) {
        if (!this.alive) return;
        
        const speed = 8;
        const yaw = this.rotation.x;
        
        this.velocity.x = (dx * Math.cos(yaw) + dz * Math.sin(yaw)) * speed;
        this.velocity.z = (dz * Math.cos(yaw) - dx * Math.sin(yaw)) * speed;
        
        this.position.x += this.velocity.x * dt;
        this.position.z += this.velocity.z * dt;
        
        // Boundary clamp
        this.position.x = Math.max(-ARENA_SIZE, Math.min(ARENA_SIZE, this.position.x));
        this.position.z = Math.max(-ARENA_SIZE, Math.min(ARENA_SIZE, this.position.z));
        
        this.camera.position.copy(this.position);
        this.camera.position.y = 1.7; // Eye height
        this.body.position.x = this.position.x;
        this.body.position.z = this.position.z;
        this.body.rotation.y = this.rotation.x;
    }
    
    aim(yawDelta, pitchDelta) {
        if (!this.alive) return;
        
        const sensitivity = 0.002;
        this.rotation.x -= yawDelta * sensitivity;
        this.rotation.y -= pitchDelta * sensitivity;
        
        // Clamp pitch
        this.rotation.y = Math.max(-Math.PI / 2, Math.min(Math.PI / 2, this.rotation.y));
        
        this.updateCameraRotation();
        this.body.rotation.y = this.rotation.x;
    }
    
    toggleIronSights(aiming) {
        this.aiming = aiming;
        
        if (aiming) {
            // Zoom in FOV and position gun for sight picture
            this.camera.fov = 25;
            this.gun.position.set(0, -0.15, -0.3);
            this.gun.rotation.y = 0;
            this.gun.rotation.x = -0.05;
        } else {
            // Normal FOV and hip position
            this.camera.fov = 75;
            this.gun.position.set(0.3, -0.4, -0.8);
            this.gun.rotation.y = -0.1;
            this.gun.rotation.x = 0;
        }
        
        this.camera.updateProjectionMatrix();
        
        // Update UI overlay
        const sights = document.getElementById(this.id === 1 ? 'p1-sights' : 'p2-sights');
        if (sights) sights.classList.toggle('active', aiming);
        
        const viewport = document.getElementById(this.id === 1 ? 'player1-viewport' : 'player2-viewport');
        if (viewport) viewport.classList.toggle('aiming', aiming);
    }
    
    advanceReload() {
        if (this.reloadState === RELOAD_STATES.READY && !this.fired) return;
        
        this.reloadProgress++;
        
        switch (this.reloadState) {
            case RELOAD_STATES.READY:
                this.reloadState = RELOAD_STATES.HALF_COCK;
                this.animateHammer(0.5); // Half cock
                break;
            case RELOAD_STATES.HALF_COCK:
                this.reloadState = RELOAD_STATES.POWDER;
                this.animatePourPowder();
                break;
            case RELOAD_STATES.POWDER:
                this.reloadState = RELOAD_STATES.PATCH_BALL;
                this.animatePatchBall();
                break;
            case RELOAD_STATES.PATCH_BALL:
                this.reloadState = RELOAD_STATES.RAMROD;
                this.ramrodStrokes = 0;
                this.animateRamrodExtend();
                break;
            case RELOAD_STATES.RAMROD:
                this.ramrodStrokes++;
                this.animateRamrodStroke();
                if (this.ramrodStrokes >= 3) {
                    this.reloadState = RELOAD_STATES.FULL_COCK;
                    this.animateRamrodRetract();
                }
                break;
            case RELOAD_STATES.FULL_COCK:
                this.reloadState = RELOAD_STATES.CAP;
                this.animateHammer(1.0); // Full cock
                break;
            case RELOAD_STATES.CAP:
                this.reloadState = RELOAD_STATES.READY;
                this.fired = false;
                this.animatePlaceCap();
                break;
        }
        
        this.updateReloadUI();
    }
    
    // Animation methods for each reload step
    animateHammer(cockLevel) {
        // Hammer rotation based on cock level
        const hammer = this.gun.userData.hammer;
        if (hammer) {
            hammer.rotation.x = 0.3 - (cockLevel * 0.4);
        }
    }
    
    animatePourPowder() {
        // Tilt gun for powder
        const targetRot = { x: -0.5, y: 0.1, z: 0 };
        this.animateGunTo(targetRot, 0.3, -0.3);
        setTimeout(() => this.resetGunPosition(), 800);
    }
    
    animatePatchBall() {
        // Gun horizontal for loading
        const targetRot = { x: -0.2, y: 0, z: 0 };
        this.animateGunTo(targetRot, 0.2, -0.4);
        setTimeout(() => this.resetGunPosition(), 600);
    }
    
    animateRamrodExtend() {
        this.gun.userData.ramrodExtended = true;
        const ramrod = this.gun.userData.ramrod;
        if (ramrod) {
            ramrod.position.z = 3.5;
            ramrod.rotation.x = Math.PI / 2 + 0.3;
        }
    }
    
    animateRamrodStroke() {
        const ramrod = this.gun.userData.ramrod;
        if (ramrod) {
            // Stroke animation
            const startZ = ramrod.position.z;
            const downZ = 1.0;
            
            const strokeDown = () => {
                ramrod.position.z = downZ;
                ramrod.position.y = -0.1;
                setTimeout(strokeUp, 300);
            };
            
            const strokeUp = () => {
                ramrod.position.z = startZ;
                ramrod.position.y = -0.35;
            };
            
            strokeDown();
        }
    }
    
    animateRamrodRetract() {
        const ramrod = this.gun.userData.ramrod;
        if (ramrod) {
            ramrod.position.z = 1.5;
            ramrod.rotation.x = Math.PI / 2;
            this.gun.userData.ramrodExtended = false;
        }
    }
    
    animatePlaceCap() {
        // Brief flash on hammer
        const hammer = this.gun.userData.hammer;
        if (hammer) {
            hammer.material = hammer.material.clone();
            hammer.material.emissive = new THREE.Color(0x333333);
            setTimeout(() => {
                hammer.material.emissive = new THREE.Color(0x000000);
            }, 200);
        }
    }
    
    animateGunTo(rot, x, y) {
        this.gun.rotation.set(rot.x, rot.y, rot.z);
        this.gun.position.set(x, y, this.gun.position.z);
    }
    
    resetGunPosition() {
        if (this.aiming) {
            this.gun.position.set(0, -0.15, -0.3);
            this.gun.rotation.set(-0.05, 0, 0);
        } else {
            this.gun.position.set(0.3, -0.4, -0.8);
            this.gun.rotation.set(0, -0.1, 0);
        }
    }
    
    updateReloadUI() {
        const statusEl = document.getElementById(this.id === 1 ? 'p1-reload' : 'p2-reload');
        const sequenceEl = document.getElementById(this.id === 1 ? 'p1-sequence' : 'p2-sequence');
        const roundEl = document.getElementById(this.id === 1 ? 'p1-round' : 'p2-round');
        
        if (statusEl) {
            statusEl.textContent = RELOAD_NAMES[this.reloadState + (this.reloadState === RELOAD_STATES.RAMROD ? this.ramrodStrokes : 0)];
            statusEl.className = 'reload-status' + (this.reloadState !== RELOAD_STATES.READY ? ' reloading' : '') + (this.fired ? ' empty' : '');
        }
        
        if (roundEl) {
            roundEl.textContent = this.fired ? '0' : '1';
        }
        
        // Show step progression
        if (sequenceEl && this.reloadState !== RELOAD_STATES.READY) {
            let steps = '';
            const totalSteps = 8;
            const currentStep = this.reloadState + (this.reloadState >= RELOAD_STATES.RAMROD ? this.ramrodStrokes - 1 : 0);
            for (let i = 0; i < totalSteps; i++) {
                if (i < currentStep - 1) steps += '✓ ';
                else if (i === currentStep - 1) steps += '▶ ';
                else steps += '○ ';
            }
            sequenceEl.textContent = steps;
        } else if (sequenceEl) {
            sequenceEl.textContent = '';
        }
    }
    
    takeDamage(amount) {
        this.health -= amount;
        if (this.health <= 0) {
            this.health = 0;
            this.alive = false;
        }
        
        const healthEl = document.getElementById(this.id === 1 ? 'p1-health' : 'p2-health');
        if (healthEl) {
            healthEl.style.width = (this.health / MAX_HEALTH * 100) + '%';
        }
    }
    
    respawn() {
        this.health = MAX_HEALTH;
        this.alive = true;
        this.fired = false;
        this.reloadState = RELOAD_STATES.READY;
        this.ramrodStrokes = 0;
        this.position.copy(this.id === 1 ? new THREE.Vector3(0, 1.7, 40) : new THREE.Vector3(0, 1.7, -40));
        this.rotation.set(0, 0);
        this.camera.position.copy(this.position);
        this.body.position.copy(this.position);
        this.body.visible = true;
        
        // Reset gun position
        this.resetGunPosition();
        this.animateHammer(0);
        
        this.updateReloadUI();
        const healthEl = document.getElementById(this.id === 1 ? 'p1-health' : 'p2-health');
        if (healthEl) healthEl.style.width = '100%';
    }
}

// ============================================
// PROJECTILE SYSTEM
// ============================================
class ProjectileSystem {
    constructor() {
        this.projectiles = [];
        this.geometry = new THREE.SphereGeometry(0.04, 8, 8);
        this.material = new THREE.MeshStandardMaterial({ 
            color: 0x8b7355,
            metalness: 0.3,
            roughness: 0.7
        });
    }
    
    spawn(position, direction, velocity, playerId) {
        const mesh = new THREE.Mesh(this.geometry, this.material);
        mesh.position.copy(position);
        scene.add(mesh);
        
        this.projectiles.push({
            mesh: mesh,
            velocity: direction.clone().multiplyScalar(velocity),
            playerId: playerId,
            distance: 0,
            maxDistance: 300
        });
    }
    
    update(dt) {
        for (let i = this.projectiles.length - 1; i >= 0; i--) {
            const p = this.projectiles[i];
            
            // Apply gravity
            p.velocity.y -= MUSKET_BALL_DROP * dt * 2;
            
            // Move
            const move = p.velocity.clone().multiplyScalar(dt);
            p.mesh.position.add(move);
            p.distance += move.length();
            
            // Check collision with players
            for (const player of [player1, player2]) {
                if (player.id !== p.playerId && player.alive) {
                    const dx = player.position.x - p.mesh.position.x;
                    const dy = (player.position.y + 0.9) - p.mesh.position.y;
                    const dz = player.position.z - p.mesh.position.z;
                    const dist = Math.sqrt(dx*dx + dy*dy + dz*dz);
                    
                    if (dist < 0.5) {
                        // Hit!
                        player.takeDamage(50);
                        this.createHitEffect(p.mesh.position);
                        scene.remove(p.mesh);
                        this.projectiles.splice(i, 1);
                        
                        if (!player.alive) {
                            endRound(player.id === 1 ? 2 : 1);
                        }
                        return;
                    }
                }
            }
            
            // Remove if too far or below ground
            if (p.distance > p.maxDistance || p.mesh.position.y < 0) {
                scene.remove(p.mesh);
                this.projectiles.splice(i, 1);
            }
        }
    }
    
    createHitEffect(position) {
        // Flash effect
        const light = new THREE.PointLight(0xffaa00, 2, 5);
        light.position.copy(position);
        scene.add(light);
        
        setTimeout(() => scene.remove(light), 100);
    }
}

// ============================================
// SMOKE SYSTEM
// ============================================
class SmokeSystem {
    constructor() {
        this.particles = [];
        this.geometry = new THREE.PlaneGeometry(2, 2);
        this.material = new THREE.MeshBasicMaterial({
            color: 0x333333,
            transparent: true,
            opacity: 0.6,
            side: THREE.DoubleSide,
            depthWrite: false
        });
    }
    
    emit(position, amount) {
        for (let i = 0; i < amount; i++) {
            const mesh = new THREE.Mesh(this.geometry, this.material.clone());
            mesh.position.copy(position);
            mesh.position.x += (Math.random() - 0.5) * 0.5;
            mesh.position.y += (Math.random() - 0.5) * 0.3;
            mesh.position.z += (Math.random() - 0.5) * 0.5;
            
            const scale = 0.5 + Math.random() * 1.5;
            mesh.scale.set(scale, scale, scale);
            mesh.rotation.z = Math.random() * Math.PI * 2;
            mesh.lookAt(position.clone().add(new THREE.Vector3(0, 1, 0)));
            
            scene.add(mesh);
            
            this.particles.push({
                mesh: mesh,
                velocity: new THREE.Vector3(
                    (Math.random() - 0.5) * 2,
                    0.5 + Math.random() * 1,
                    (Math.random() - 0.5) * 2
                ),
                life: SMOKE_LIFETIME,
                maxLife: SMOKE_LIFETIME,
                growth: 0.5 + Math.random() * 0.5
            });
        }
    }
    
    update(dt) {
        for (let i = this.particles.length - 1; i >= 0; i--) {
            const p = this.particles[i];
            
            p.life -= dt;
            
            if (p.life <= 0) {
                scene.remove(p.mesh);
                this.particles.splice(i, 1);
                continue;
            }
            
            // Move and grow
            p.mesh.position.add(p.velocity.clone().multiplyScalar(dt));
            p.mesh.position.y = Math.max(0.5, p.mesh.position.y);
            
            const growth = 1 + (p.maxLife - p.life) * p.growth * 0.3;
            p.mesh.scale.setScalar(growth);
            
            // Fade
            p.mesh.material.opacity = (p.life / p.maxLife) * 0.5;
            
            // Make smoke face cameras (billboard toward average camera position)
            const avgX = (camera1.position.x + camera2.position.x) / 2;
            const avgY = (camera1.position.y + camera2.position.y) / 2;
            const avgZ = (camera1.position.z + camera2.position.z) / 2;
            p.mesh.lookAt(avgX, avgY, avgZ);
        }
    }
}

// ============================================
// INPUT HANDLING
// ============================================
const keys = {};

window.addEventListener('keydown', (e) => {
    keys[e.key.toLowerCase()] = true;
    
    // Reload keys
    if (e.key.toLowerCase() === 'r' && gameRunning) {
        player1.advanceReload();
    }
    if ((e.key.toLowerCase() === 'o' || e.key === 'O') && gameRunning) {
        player2.advanceReload();
    }
    
    // Iron sights toggle - Player 2 (changed from H to N to avoid conflict)
    if (e.key.toLowerCase() === 'n' && gameRunning) {
        p2Aiming = !p2Aiming;
        player2.toggleIronSights(p2Aiming);
    }
});

window.addEventListener('keyup', (e) => {
    keys[e.key.toLowerCase()] = false;
});

// Mouse handling for Player 1
let mouseLocked = false;
let p2Aiming = false;

document.addEventListener('mousedown', (e) => {
    if (!gameRunning) return;
    
    // Player 1 fire (left click)
    if (e.button === 0 && !player1.fired && player1.reloadState === RELOAD_STATES.READY) {
        fireMusket(player1);
    }
    
    // Player 1 iron sights (right click)
    if (e.button === 2) {
        e.preventDefault();
        player1.toggleIronSights(true);
    }
    
    // Player 2 fire (Y key check in loop)
});

document.addEventListener('mouseup', (e) => {
    if (e.button === 2) {
        player1.toggleIronSights(false);
    }
});

document.addEventListener('mousemove', (e) => {
    if (gameRunning) {
        // Player 1 mouse aim
        player1.aim(e.movementX, e.movementY);
    }
});

document.addEventListener('contextmenu', e => e.preventDefault());

// ============================================
// GAME STATE
// ============================================
let player1, player2;
let camera1, camera2;
let projectiles, smoke;
let gameRunning = false;

function initGame() {
    // Create players at opposite ends
    player1 = new Player(1, new THREE.Vector3(0, 1.7, 40), new THREE.Vector2(Math.PI, 0));
    player2 = new Player(2, new THREE.Vector3(0, 1.7, -40), new THREE.Vector2(0, 0));
    
    camera1 = player1.camera;
    camera2 = player2.camera;
    
    projectiles = new ProjectileSystem();
    smoke = new SmokeSystem();
    
    // Lock mouse for Player 1
    document.getElementById('canvas1').requestPointerLock = 
        document.getElementById('canvas1').requestPointerLock ||
        document.getElementById('canvas1').mozRequestPointerLock;
    
    document.getElementById('canvas1').addEventListener('click', () => {
        document.getElementById('canvas1').requestPointerLock();
    });
}

function fireMusket(player) {
    if (player.fired || player.reloadState !== RELOAD_STATES.READY) return;
    
    player.fired = true;
    
    // Get muzzle position from gun model
    const gunWorldPos = new THREE.Vector3();
    player.gun.userData.barrel.getWorldPosition(gunWorldPos);
    
    // Get aim direction from camera
    const direction = new THREE.Vector3(0, 0, -1);
    direction.applyQuaternion(player.camera.quaternion);
    
    // Add slight inaccuracy (smoothbore musket)
    direction.x += (Math.random() - 0.5) * 0.02;
    direction.y += (Math.random() - 0.5) * 0.02;
    direction.z += (Math.random() - 0.5) * 0.02;
    direction.normalize();
    
    // Spawn projectile
    projectiles.spawn(gunWorldPos, direction, MUSKET_BALL_SPEED, player.id);
    
    // Muzzle flash
    const flash = new THREE.PointLight(0xffaa00, 5, 10);
    flash.position.copy(gunWorldPos);
    scene.add(flash);
    setTimeout(() => scene.remove(flash), 50);
    
    // Smoke burst at muzzle and position
    smoke.emit(gunWorldPos, 8);
    smoke.emit(player.position.clone().add(new THREE.Vector3(0, 1.5, 0)), 15);
    
    // Screen flash for firing player (white flash on their viewport)
    const viewport = document.getElementById(player.id === 1 ? 'player1-viewport' : 'player2-viewport');
    viewport.style.background = '#fff';
    setTimeout(() => viewport.style.background = '', 50);
    
    // Kick animation
    const kickRot = { x: 0.3, y: player.gun.rotation.y, z: player.gun.rotation.z };
    player.gun.rotation.x = kickRot.x;
    setTimeout(() => player.resetGunPosition(), 150);
    
    // Hammer falls
    player.animateHammer(0);
    
    // Update UI
    player.updateReloadUI();
    
    // Show enemy's gun smoke (visual representation)
    const otherPlayer = player.id === 1 ? player2 : player1;
    const enemyGun = otherPlayer.body.userData.gun;
    if (enemyGun) {
        smoke.emit(otherPlayer.position.clone().add(new THREE.Vector3(0.3, 1.2, 0.4)), 20);
    }
}

// ============================================
// GAME LOOP
// ============================================
const clock = new THREE.Clock();

function gameLoop() {
    requestAnimationFrame(gameLoop);
    
    const dt = clock.getDelta();
    
    if (!gameRunning) return;
    
    // Player 1 movement (WASD)
    let p1MoveX = 0, p1MoveZ = 0;
    if (keys['w']) p1MoveZ -= 1;
    if (keys['s']) p1MoveZ += 1;
    if (keys['a']) p1MoveX -= 1;
    if (keys['d']) p1MoveX += 1;
    if (p1MoveX !== 0 || p1MoveZ !== 0) {
        player1.move(p1MoveX, p1MoveZ, dt);
    }
    
    // Player 2 movement (IJKL)
    let p2MoveX = 0, p2MoveZ = 0;
    if (keys['i']) p2MoveZ -= 1;
    if (keys['k']) p2MoveZ += 1;
    if (keys['j']) p2MoveX -= 1;
    if (keys['l']) p2MoveX += 1;
    if (p2MoveX !== 0 || p2MoveZ !== 0) {
        player2.move(p2MoveX, p2MoveZ, dt);
    }
    
    // Player 2 aim (Y=up, H=down, U=left, O=right)
    let p2AimYaw = 0, p2AimPitch = 0;
    if (keys['u']) p2AimYaw = 100;
    if (keys['o']) p2AimYaw = -100;
    if (keys['y']) p2AimPitch = -100;
    if (keys['h'] && !p2Aiming) p2AimPitch = 100;
    if (p2AimYaw !== 0 || p2AimPitch !== 0) {
        player2.aim(p2AimYaw * dt * 10, p2AimPitch * dt * 10);
    }
    
    // Player 2 fire (Y key when aiming)
    if (keys['y'] && !player2.fired && player2.reloadState === RELOAD_STATES.READY && p2Aiming) {
        // Use a cooldown to prevent auto-fire from held key
        if (!player2.fireCooldown) {
            fireMusket(player2);
            player2.fireCooldown = true;
            setTimeout(() => player2.fireCooldown = false, 500);
        }
    }
    
    // Update systems
    projectiles.update(dt);
    smoke.update(dt);
    
    // Render split-screen
    renderer1.render(scene, camera1);
    renderer2.render(scene, camera2);
}

// ============================================
// UI AND GAME FLOW
// ============================================
function startGame() {
    document.getElementById('menu-screen').classList.add('hidden');
    document.getElementById('victory-screen').classList.remove('visible');
    
    if (!player1) initGame();
    
    player1.respawn();
    player2.respawn();
    
    // Clear projectiles and smoke
    for (const p of projectiles.projectiles) scene.remove(p.mesh);
    projectiles.projectiles = [];
    for (const s of smoke.particles) scene.remove(s.mesh);
    smoke.particles = [];
    
    gameRunning = true;
    
    // Request pointer lock for Player 1
    document.getElementById('canvas1').requestPointerLock();
}

function endRound(winnerId) {
    gameRunning = false;
    
    document.exitPointerLock = document.exitPointerLock || document.mozExitPointerLock;
    document.exitPointerLock();
    
    document.getElementById('winner-text').textContent = `PLAYER ${winnerId} WINS!`;
    document.getElementById('victory-screen').classList.add('visible');
}

// Button listeners
document.getElementById('start-btn').addEventListener('click', startGame);
document.getElementById('rematch-btn').addEventListener('click', startGame);

// Window resize
window.addEventListener('resize', () => {
    const width = window.innerWidth;
    const height = window.innerHeight;
    
    renderer1.setSize(width, height / 2);
    renderer2.setSize(width, height / 2);
    
    if (player1) {
        player1.camera.aspect = width / (height / 2);
        player1.camera.updateProjectionMatrix();
    }
    if (player2) {
        player2.camera.aspect = width / (height / 2);
        player2.camera.updateProjectionMatrix();
    }
});

// Start loop
gameLoop();
