// InputManager.js - Handles dual player input with isolation
class InputManager {
    constructor() {
        this.keys = {};
        this.mouse = { x: 0, y: 0, movementX: 0, movementY: 0 };
        this.player2Mouse = { x: 0, y: 0 };
        this.mouseLocked = false;
        
        // Input bindings
        this.bindings = {
            player1: {
                forward: 'w',
                backward: 's',
                left: 'a',
                right: 'd',
                strafeLeft: 'q',
                strafeRight: 'e',
                fire: 'f',
                reload: 'r',
                aim: 'mouse'
            },
            player2: {
                forward: 'i',
                backward: 'k',
                left: 'j',
                right: 'l',
                strafeLeft: 'u',
                strafeRight: 'o',
                fire: [';', 'enter'],
                reload: 'p',
                aim: 'arrows'
            }
        };
        
        // Prevent key repeat for actions
        this.keyPressed = {};
        this.keyHandled = {};
        
        this.setupListeners();
    }
    
    setupListeners() {
        // Keyboard
        document.addEventListener('keydown', (e) => {
            this.keys[e.key.toLowerCase()] = true;
            
            // Also track numpad keys
            if (e.code.startsWith('Numpad')) {
                this.keys[e.code] = true;
            }
            
            if (!this.keyPressed[e.key.toLowerCase()]) {
                this.keyPressed[e.key.toLowerCase()] = true;
                this.keyHandled[e.key.toLowerCase()] = false;
            }
        });
        
        document.addEventListener('keyup', (e) => {
            this.keys[e.key.toLowerCase()] = false;
            this.keyPressed[e.key.toLowerCase()] = false;
            this.keyHandled[e.key.toLowerCase()] = false;
            
            if (e.code.startsWith('Numpad')) {
                this.keys[e.code] = false;
            }
        });
        
        // Mouse (for Player 1)
        document.addEventListener('mousemove', (e) => {
            if (this.mouseLocked) {
                this.mouse.movementX = e.movementX;
                this.mouse.movementY = e.movementY;
            }
        });
        
        document.addEventListener('mousedown', (e) => {
            this.mouse.buttons = e.buttons;
            if (e.button === 0) { // Left click
                this.keys['mouseleft'] = true;
            }
        });
        
        document.addEventListener('mouseup', (e) => {
            this.mouse.buttons = e.buttons;
            if (e.button === 0) {
                this.keys['mouseleft'] = false;
                this.keyPressed['mouseleft'] = false;
                this.keyHandled['mouseleft'] = false;
            }
        });
        
        // Pointer lock for FPS mouse
        const canvas = document.getElementById('game-canvas');
        if (canvas) {
            canvas.addEventListener('click', () => {
                if (!this.mouseLocked && document.getElementById('start-screen').style.display === 'none') {
                    canvas.requestPointerLock();
                }
            });
            
            document.addEventListener('pointerlockchange', () => {
                this.mouseLocked = document.pointerLockElement === canvas;
            });
        }
    }
    
    isPressed(player, action) {
        const binding = this.bindings[player][action];
        if (!binding) return false;
        
        if (binding === 'mouse') {
            // Player 1 uses mouse
            return this.mouse.movementX !== 0 || this.mouse.movementY !== 0;
        }
        
        if (binding === 'arrows') {
            // Player 2 uses arrow keys for aiming
            return this.keys['arrowleft'] || this.keys['arrowright'] || 
                   this.keys['arrowup'] || this.keys['arrowdown'];
        }
        
        return this.keys[binding];
    }
    
    isJustPressed(player, action) {
        const binding = this.bindings[player][action];
        if (!binding) return false;
        
        const key = binding === 'mouse' ? 'mouseleft' : 
                      binding === 'arrows' ? 'enter' : binding;
        
        if (this.keyPressed[key] && !this.keyHandled[key]) {
            this.keyHandled[key] = true;
            return true;
        }
        return false;
    }
    
    getMovement(player) {
        const b = this.bindings[player];
        let forward = 0;
        let right = 0;
        
        if (player === 'player1') {
            if (this.keys[b.forward]) forward += 1;
            if (this.keys[b.backward]) forward -= 1;
            if (this.keys[b.left]) right -= 1;
            if (this.keys[b.right]) right += 1;
        } else {
            if (this.keys[b.forward]) forward += 1;
            if (this.keys[b.backward]) forward -= 1;
            if (this.keys[b.left]) right -= 1;
            if (this.keys[b.right]) right += 1;
            
            // Also support arrow keys for aim when not moving
            if (this.keys['arrowup']) forward += 1;
            if (this.keys['arrowdown']) forward -= 1;
            if (this.keys['arrowleft']) right -= 1;
            if (this.keys['arrowright']) right += 1;
        }
        
        return { forward, right };
    }
    
    getAimDelta(player) {
        if (player === 'player1' && this.mouseLocked) {
            const dx = this.mouse.movementX * 0.002;
            const dy = this.mouse.movementY * 0.002;
            
            // Reset after reading
            this.mouse.movementX = 0;
            this.mouse.movementY = 0;
            
            return { x: dx, y: dy };
        } else if (player === 'player2') {
            // Player 2 uses arrow keys for aim
            let dx = 0;
            let dy = 0;
            
            if (this.keys['arrowleft']) dx -= 0.03;
            if (this.keys['arrowright']) dx += 0.03;
            if (this.keys['arrowup']) dy -= 0.03;
            if (this.keys['arrowdown']) dy += 0.03;
            
            return { x: dx, y: dy };
        }
        
        return { x: 0, y: 0 };
    }
    
    // Alternative P2 controls using numpad for better isolation
    getP2AltControls() {
        // Numpad 8/4/5/6 for aim
        let dx = 0;
        let dy = 0;
        
        if (this.keys['Numpad4']) dx -= 0.03;
        if (this.keys['Numpad6']) dx += 0.03;
        if (this.keys['Numpad8']) dy -= 0.03;
        if (this.keys['Numpad5'] || this.keys['Numpad2']) dy += 0.03;
        
        return { x: dx, y: dy };
    }
    
    reset() {
        this.keys = {};
        this.keyPressed = {};
        this.keyHandled = {};
        this.mouse.movementX = 0;
        this.mouse.movementY = 0;
    }
    
    releasePointerLock() {
        if (document.pointerLockElement) {
            document.exitPointerLock();
        }
        this.mouseLocked = false;
    }
}

if (typeof module !== 'undefined' && module.exports) {
    module.exports = InputManager;
}
