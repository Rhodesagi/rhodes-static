<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MUSKETS FIRE ONE - 2 Player Musket Duel</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <div id="game-container">
        <div id="viewport-p1" class="viewport">
            <div class="player-label">PLAYER 1</div>
            <div class="controls-hint">
                Move: WASD | Aim: IJKL | Fire: O | Reload: P | Iron Sights: Hold Space
            </div>
        </div>
        <div id="viewport-p2" class="viewport">
            <div class="player-label">PLAYER 2</div>
            <div class="controls-hint">
                Move: Arrows | Aim: Num 8456 | Fire: Num 0 | Reload: Num Enter | Sights: Num 7 | OR Gamepad
            </div>
        </div>
    </div>
    
    <div id="start-screen">
        <h1>MUSKETS FIRE ONE</h1>
        <p>A historically authentic black powder duel</p>
        <div class="instructions">
            <h3>How to Play:</h3>
            <ul>
                <li>Each player has ONE shot before reloading</li>
                <li>Full reload sequence: powder, patch, ball, ram, prime</li>
                <li>Hold iron sights key for precise aiming (narrower FOV)</li>
                <li>Projectiles have realistic drop - aim high at distance</li>
                <li>First to 5 hits wins</li>
            </ul>
        </div>
        <button id="start-btn">START DUEL</button>
    </div>
    
    <div id="score-display">
        <span id="score-p1">P1: 0</span>
        <span id="round-timer">--</span>
        <span id="score-p2">P2: 0</span>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="js/audio.js"></script>
    <script src="js/input.js"></script>
    <script src="js/physics.js"></script>
    <script src="js/musket.js"></script>
    <script src="js/sights.js"></script>
    <script src="js/player.js"></script>
    <script src="js/renderer.js"></script>
    <script src="js/game.js"></script>
</body>
</html>
