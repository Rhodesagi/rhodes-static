// Input handling with keyboard matrix awareness + Gamepad API support
// P1: Left side of keyboard (WASD + IOP) OR Gamepad
// P2: Right side (Numpad) OR Gamepad
// This avoids matrix ghosting conflicts

class InputHandler {
    constructor() {
        this.keys = {};
        this.keysPressed = {};
        this.keysReleased = {};
        
        // Player 1 key mappings (left side)
        this.p1Keys = {
            forward: 'KeyW',
            backward: 'KeyS',
            left: 'KeyA',
            right: 'KeyD',
            aimUp: 'KeyI',
            aimDown: 'KeyK',
            aimLeft: 'KeyJ',
            aimRight: 'KeyL',
            fire: 'KeyO',
            reload: 'KeyP',
            ironSights: 'Space'
        };
        
        // Player 2 key mappings (numpad for minimal conflict)
        this.p2Keys = {
            forward: 'ArrowUp',
            backward: 'ArrowDown',
            left: 'ArrowLeft',
            right: 'ArrowRight',
            aimUp: 'Numpad8',
            aimDown: 'Numpad5',
            aimLeft: 'Numpad4',
            aimRight: 'Numpad6',
            fire: 'Numpad0',
            reload: 'NumpadEnter',
            ironSights: 'Numpad7'
        };
        
        // Gamepad state
        this.gamepads = {};
        this.prevGamepadButtons = {};
        
        this.setupListeners();
        this.setupGamepad();
    }
    
    setupGamepad() {
        // Listen for gamepad connections
        window.addEventListener('gamepadconnected', (e) => {
            console.log('Gamepad connected:', e.gamepad.id);
            this.gamepads[e.gamepad.index] = e.gamepad;
        });
        
        window.addEventListener('gamepaddisconnected', (e) => {
            console.log('Gamepad disconnected:', e.gamepad.id);
            delete this.gamepads[e.gamepad.index];
        });
    }
    
    getGamepadInput(playerNum) {
        const gamepadIndex = playerNum === 1 ? 0 : 1;
        const gamepad = this.gamepads[gamepadIndex];
        
        if (!gamepad) {
            return null;
        }
        
        // Get fresh gamepad state
        const gp = navigator.getGamepads()[gamepadIndex];
        if (!gp) return null;
        
        // Store previous button states for pressed detection
        const prevKey = `p${playerNum}`;
        const wasPressed = this.prevGamepadButtons[prevKey] || {};
        
        // Left stick for movement
        const moveX = gp.axes[0];
        const moveY = gp.axes[1];
        
        // Right stick for aiming
        const aimX = gp.axes[2] || gp.axes[0]; // Fallback if no right stick
        const aimY = gp.axes[3] || gp.axes[1];
        
        // Deadzone
        const deadzone = 0.15;
        
        // Buttons (Xbox layout)
        const aButton = gp.buttons[0].pressed; // Fire
        const bButton = gp.buttons[1].pressed; // Reload
        const xButton = gp.buttons[2].pressed; // Iron sights
        
        // Detect button presses (rising edge)
        const firePressed = aButton && !wasPressed.a;
        const reloadPressed = bButton && !wasPressed.b;
        
        // Update previous state
        this.prevGamepadButtons[prevKey] = {
            a: aButton,
            b: bButton,
            x: xButton
        };
        
        return {
            moveForward: moveY < -deadzone,
            moveBackward: moveY > deadzone,
            moveLeft: moveX < -deadzone,
            moveRight: moveX > deadzone,
            aimUp: aimY < -deadzone,
            aimDown: aimY > deadzone,
            aimLeft: aimX < -deadzone,
            aimRight: aimX > deadzone,
            fire: firePressed,
            reload: reloadPressed,
            ironSights: xButton
        };
    }
    
    setupListeners() {
        document.addEventListener('keydown', (e) => {
            if (!this.keys[e.code]) {
                this.keysPressed[e.code] = true;
            }
            this.keys[e.code] = true;
            
            // Prevent default for game keys to avoid page scrolling
            if (this.isGameKey(e.code)) {
                e.preventDefault();
            }
        });
        
        document.addEventListener('keyup', (e) => {
            this.keys[e.code] = false;
            this.keysReleased[e.code] = true;
        });
    }
    
    isGameKey(code) {
        const gameKeys = [
            ...Object.values(this.p1Keys),
            ...Object.values(this.p2Keys)
        ];
        return gameKeys.includes(code);
    }
    
    // Check if key is currently held
    isHeld(keyCode) {
        return !!this.keys[keyCode];
    }
    
    // Check if key was pressed this frame (one-shot)
    wasPressed(keyCode) {
        const pressed = !!this.keysPressed[keyCode];
        this.keysPressed[keyCode] = false;
        return pressed;
    }
    
    // Check if key was released this frame
    wasReleased(keyCode) {
        const released = !!this.keysReleased[keyCode];
        this.keysReleased[keyCode] = false;
        return released;
    }
    
    // Get player 1 input state
    getP1Input() {
        return {
            moveForward: this.isHeld(this.p1Keys.forward),
            moveBackward: this.isHeld(this.p1Keys.backward),
            moveLeft: this.isHeld(this.p1Keys.left),
            moveRight: this.isHeld(this.p1Keys.right),
            aimUp: this.isHeld(this.p1Keys.aimUp),
            aimDown: this.isHeld(this.p1Keys.aimDown),
            aimLeft: this.isHeld(this.p1Keys.aimLeft),
            aimRight: this.isHeld(this.p1Keys.aimRight),
            fire: this.wasPressed(this.p1Keys.fire),
            reload: this.wasPressed(this.p1Keys.reload),
            ironSights: this.isHeld(this.p1Keys.ironSights)
        };
    }
    
    // Get player 2 input state
    getP2Input() {
        return {
            moveForward: this.isHeld(this.p2Keys.forward),
            moveBackward: this.isHeld(this.p2Keys.backward),
            moveLeft: this.isHeld(this.p2Keys.left),
            moveRight: this.isHeld(this.p2Keys.right),
            aimUp: this.isHeld(this.p2Keys.aimUp),
            aimDown: this.isHeld(this.p2Keys.aimDown),
            aimLeft: this.isHeld(this.p2Keys.aimLeft),
            aimRight: this.isHeld(this.p2Keys.aimRight),
            fire: this.wasPressed(this.p2Keys.fire),
            reload: this.wasPressed(this.p2Keys.reload),
            ironSights: this.isHeld(this.p2Keys.ironSights)
        };
    }
    
    // Reset all pressed/released states
    reset() {
        this.keysPressed = {};
        this.keysReleased = {};
    }
}

// Create global input handler
const input = new InputHandler();
