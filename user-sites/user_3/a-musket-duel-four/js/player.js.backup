// Player controller with iron sight aiming
class Player {
    constructor(scene, isPlayer2 = false) {
        this.scene = scene;
        this.isPlayer2 = isPlayer2;
        this.alive = true;
        
        // Position and rotation
        this.position = new THREE.Vector3(
            isPlayer2 ? 10 : -10,
            0,
            isPlayer2 ? 0 : 0
        );
        this.rotation = new THREE.Euler(0, isPlayer2 ? -Math.PI / 2 : Math.PI / 2, 0);
        this.musketRotation = new THREE.Euler(0, 0, 0);
        
        // Movement
        this.moveSpeed = 4;
        this.turnSpeed = 1.5;
        this.velocity = new THREE.Vector3();
        
        // Iron sight properties
        this.normalFOV = 75;
        this.aimFOV = 45;
        this.aimHeight = 1.6;
        this.normalHeight = 1.5;
        
        // Create player mesh
        this.createMesh();
        
        // Create musket
        this.musket = new Musket(scene, isPlayer2);
        
        // Camera
        this.camera = null; // Set by game
    }
    
    createMesh() {
        const coatColor = this.isPlayer2 ? 0x8B0000 : 0x191970;
        const pantsColor = 0xF5F5DC;
        
        this.mesh = new THREE.Group();
        
        // Body (torso)
        const bodyGeo = new THREE.BoxGeometry(0.5, 0.7, 0.3);
        const bodyMat = new THREE.MeshLambertMaterial({ color: coatColor });
        const body = new THREE.Mesh(bodyGeo, bodyMat);
        body.position.y = 1.1;
        this.mesh.add(body);
        
        // Head
        const headGeo = new THREE.BoxGeometry(0.35, 0.4, 0.35);
        const headMat = new THREE.MeshLambertMaterial({ color: 0xFFDBAC });
        const head = new THREE.Mesh(headGeo, headMat);
        head.position.y = 1.65;
        this.mesh.add(head);
        
        // Tricorne hat
        const hatGroup = new THREE.Group();
        const hatBrimGeo = new THREE.CylinderGeometry(0.4, 0.4, 0.05, 8);
        const hatMat = new THREE.MeshLambertMaterial({ color: 0x1a1a1a });
        const hatBrim = new THREE.Mesh(hatBrimGeo, hatMat);
        hatBrim.scale.set(1, 1, 0.8);
        hatGroup.add(hatBrim);
        
        const hatCrownGeo = new THREE.CylinderGeometry(0.2, 0.25, 0.25, 8);
        const hatCrown = new THREE.Mesh(hatCrownGeo, hatMat);
        hatCrown.position.y = 0.15;
        hatGroup.add(hatCrown);
        
        hatGroup.position.y = 1.95;
        hatGroup.rotation.z = this.isPlayer2 ? -0.2 : 0.2;
        this.mesh.add(hatGroup);
        
        // Legs
        const legGeo = new THREE.BoxGeometry(0.18, 0.9, 0.2);
        const legMat = new THREE.MeshLambertMaterial({ color: pantsColor });
        
        const leftLeg = new THREE.Mesh(legGeo, legMat);
        leftLeg.position.set(-0.15, 0.45, 0);
        this.mesh.add(leftLeg);
        
        const rightLeg = new THREE.Mesh(legGeo, legMat);
        rightLeg.position.set(0.15, 0.45, 0);
        this.mesh.add(rightLeg);
        
        // Arms
        const armGeo = new THREE.BoxGeometry(0.12, 0.7, 0.12);
        const armMat = new THREE.MeshLambertMaterial({ color: coatColor });
        
        this.leftArm = new THREE.Mesh(armGeo, armMat);
        this.leftArm.position.set(-0.35, 1.2, 0.2);
        this.leftArm.rotation.x = -0.5;
        this.mesh.add(this.leftArm);
        
        this.rightArm = new THREE.Mesh(armGeo, armMat);
        this.rightArm.position.set(0.35, 1.2, 0.2);
        this.rightArm.rotation.x = -0.5;
        this.mesh.add(this.rightArm);
        
        this.scene.add(this.mesh);
    }
    
    update(input, deltaTime, otherPlayer) {
        if (!this.alive) return;
        
        // Movement (WASD for P1, IJKL for P2)
        const moveVector = new THREE.Vector3();
        
        if (this.isPlayer2) {
            if (input.keys['KeyI']) moveVector.z -= 1;
            if (input.keys['KeyK']) moveVector.z += 1;
            if (input.keys['KeyJ']) moveVector.x -= 1;
            if (input.keys['KeyL']) moveVector.x += 1;
        } else {
            if (input.keys['KeyW']) moveVector.z -= 1;
            if (input.keys['KeyS']) moveVector.z += 1;
            if (input.keys['KeyA']) moveVector.x -= 1;
            if (input.keys['KeyD']) moveVector.x += 1;
        }
        
        // Normalize and apply rotation
        if (moveVector.length() > 0) {
            moveVector.normalize();
            moveVector.multiplyScalar(this.moveSpeed * deltaTime);
            moveVector.applyEuler(new THREE.Euler(0, this.rotation.y, 0));
            
            // Collision check with other player
            const newPos = this.position.clone().add(moveVector);
            if (newPos.distanceTo(otherPlayer.position) > 1.2) {
                this.position.add(moveVector);
            }
        }
        
        // Keep in bounds
        this.position.x = Math.max(-48, Math.min(48, this.position.x));
        this.position.z = Math.max(-48, Math.min(48, this.position.z));
        
        // Musket turning (Q/E for P1, U/O for P2)
        const turnInput = this.isPlayer2 ? 
            (input.keys['KeyU'] ? 1 : 0) - (input.keys['KeyO'] ? 1 : 0) :
            (input.keys['KeyQ'] ? 1 : 0) - (input.keys['KeyE'] ? 1 : 0);
        
        if (!this.musket.aiming) {
            this.musketRotation.y += turnInput * this.turnSpeed * deltaTime;
            this.musketRotation.y = Math.max(-0.6, Math.min(0.6, this.musketRotation.y));
        } else {
            // Fine adjustment when aiming
            this.musketRotation.y += turnInput * this.turnSpeed * 0.3 * deltaTime;
            this.musketRotation.y = Math.max(-0.3, Math.min(0.3, this.musketRotation.y));
        }
        
        // Aiming (X for P1, M for P2)
        const aimKey = this.isPlayer2 ? 'KeyM' : 'KeyX';
        const wasAiming = this.musket.aiming;
        this.musket.aim(input.keys[aimKey] || false);
        
        // Update camera FOV for iron sights
        if (this.camera) {
            const targetFOV = this.musket.aiming ? this.aimFOV : this.normalFOV;
            this.camera.fov += (targetFOV - this.camera.fov) * 10 * deltaTime;
            this.camera.updateProjectionMatrix();
        }
        
        // Reloading (R for P1, P for P2)
        const reloadKey = this.isPlayer2 ? 'KeyP' : 'KeyR';
        if (input.keys[reloadKey] && !input.prevKeys[reloadKey]) {
            this.musket.startReload();
        }
        
        // Update reload
        this.musket.updateReload(deltaTime);
        
        // Firing (F for P1, H for P2)
        const fireKey = this.isPlayer2 ? 'KeyH' : 'KeyF';
        if (input.keys[fireKey] && !input.prevKeys[fireKey]) {
            this.fire();
        }
        
        // Update mesh position
        this.mesh.position.copy(this.position);
        this.mesh.rotation.y = this.rotation.y;
        
        // Animate arms based on aim
        if (this.musket.aiming) {
            this.leftArm.rotation.x = -1.2;
            this.leftArm.rotation.z = 0.3;
            this.rightArm.rotation.x = -1.3;
            this.rightArm.rotation.z = -0.3;
        } else {
            this.leftArm.rotation.x = -0.5;
            this.leftArm.rotation.z = 0;
            this.rightArm.rotation.x = -0.5;
            this.rightArm.rotation.z = 0;
        }
        
        // Update musket position
        const musketPos = this.position.clone();
        musketPos.y += this.musket.aiming ? this.aimHeight : this.normalHeight;
        
        const musketRot = this.rotation.clone();
        musketRot.y += this.musketRotation.y;
        musketRot.x += this.musket.aiming ? -0.05 : 0;
        
        this.musket.setPosition(musketPos, musketRot);
    }
    
    fire() {
        const firePos = this.position.clone();
        firePos.y += this.musket.aiming ? this.aimHeight : this.normalHeight;
        
        const fireRot = this.rotation.clone();
        fireRot.y += this.musketRotation.y;
        fireRot.x += this.musket.aiming ? -0.05 : 0;
        
        return this.musket.fire(firePos, fireRot);
    }
    
    getCameraPosition() {
        const camPos = this.position.clone();
        camPos.y += this.musket.aiming ? this.aimHeight + 0.05 : this.normalHeight + 0.1;
        
        // Offset based on musket rotation
        const offset = new THREE.Vector3(
            Math.sin(this.rotation.y + this.musketRotation.y) * 0.15,
            0,
            Math.cos(this.rotation.y + this.musketRotation.y) * 0.15
        );
        camPos.add(offset);
        
        return camPos;
    }
    
    getCameraRotation() {
        const rot = this.rotation.clone();
        rot.y += this.musketRotation.y;
        if (this.musket.aiming) {
            rot.x = -0.03; // Slight down tilt for sights
        }
        return rot;
    }
    
    die() {
        this.alive = false;
        // Fall animation
        this.mesh.rotation.z = this.isPlayer2 ? -Math.PI / 2 : Math.PI / 2;
        this.mesh.position.y = 0.3;
    }
    
    reset() {
        this.alive = true;
        this.position.set(
            this.isPlayer2 ? 10 : -10,
            0,
            this.isPlayer2 ? 0 : 0
        );
        this.rotation.y = this.isPlayer2 ? -Math.PI / 2 : Math.PI / 2;
        this.musketRotation.set(0, 0, 0);
        this.mesh.rotation.z = 0;
        this.mesh.position.y = 0;
        this.musket.reset();
    }
}