* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #000;
    font-family: 'Georgia', serif;
}

#game-container {
    position: relative;
    width: 100vw;
    height: 100vh;
}

#game-canvas {
    display: block;
    width: 100%;
    height: 100%;
}

#instructions {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(20, 15, 10, 0.95);
    border: 3px solid #8B4513;
    padding: 40px 60px;
    border-radius: 8px;
    color: #D4AF37;
    text-align: center;
    display: flex;
    gap: 60px;
}

.player-controls {
    text-align: left;
}

.player-controls h3 {
    color: #F4E4C1;
    margin-bottom: 15px;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: 2px;
}

.player-controls p {
    margin: 8px 0;
    font-size: 14px;
    color: #C9B896;
}

#start-hint {
    position: absolute;
    bottom: -50px;
    left: 50%;
    transform: translateX(-50%);
    color: #8B7355;
    font-style: italic;
    white-space: nowrap;
}

#victory {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(20, 15, 10, 0.98);
    border: 4px solid #D4AF37;
    padding: 60px 100px;
    border-radius: 12px;
    color: #F4E4C1;
    text-align: center;
}

#victory h1 {
    font-size: 48px;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 4px;
}

#victory p {
    color: #8B7355;
    font-size: 18px;
}

.hidden {
    display: none !important;
}

/* No artificial overlays during gameplay */
.game-active #instructions {
    display: none;
}

/* Iron sight visual styling - only when aiming */
.aiming {
    filter: contrast(1.1) saturate(0.9);
}