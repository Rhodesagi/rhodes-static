<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MUSKETS FIRE THREE</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: #000;
            overflow: hidden;
            font-family: 'Courier New', monospace;
        }
        #gameContainer {
            width: 100vw;
            height: 100vh;
            position: relative;
        }
        canvas {
            display: block;
            width: 100%;
            height: 100%;
        }
        #instructions {
            position: absolute;
            top: 10px;
            left: 50%;
            transform: translateX(-50%);
            color: #888;
            font-size: 12px;
            text-align: center;
            z-index: 100;
            background: rgba(0,0,0,0.8);
            padding: 8px 20px;
            border-radius: 3px;
            border: 1px solid #333;
        }
        .playerLabel {
            position: absolute;
            bottom: 15px;
            color: #666;
            font-size: 16px;
            font-weight: bold;
            z-index: 100;
            text-shadow: 0 0 5px rgba(0,0,0,0.8);
        }
        #p1Label { left: 25%; transform: translateX(-50%); }
        #p2Label { right: 25%; transform: translateX(50%); }
        #divider {
            position: absolute;
            left: 50%;
            top: 0;
            width: 3px;
            height: 100%;
            background: #333;
            z-index: 50;
            transform: translateX(-50%);
        }
    </style>
</head>
<body>
    <div id="gameContainer">
        <div id="instructions">
            P1: WASD Move | Q Aim | E Fire | R Reload<br>
            P2: IJKL Move | U Aim | O Fire | P Reload
        </div>
        <div id="divider"></div>
        <div class="playerLabel" id="p1Label">SOLDIER 1</div>
        <div class="playerLabel" id="p2Label">SOLDIER 2</div>
    </div>

    <script type="importmap">
    {
        "imports": {
            "three": "https://unpkg.com/three@0.160.0/build/three.module.js"
        }
    }
    </script>

    <script type="module">
        import * as THREE from 'three';

        // ============================================
        // MUSKETS FIRE THREE - 2 Player Split Screen FPS
        // Flintlock musket combat with iron sights only
        // ============================================

        const GAME_CONFIG = {
            walkSpeed: 4,
            turnSpeed: 0.025,
            musketVelocity: 137, // m/s (~450 fps)
            gravity: 9.8,
            reloadStages: [
                { name: 'half-cock', duration: 0.5 },
                { name: 'frizzen-open', duration: 0.3 },
                { name: 'prime-pan', duration: 0.8 },
                { name: 'close-frizzen', duration: 0.3 },
                { name: 'charge-barrel', duration: 1.0 },
                { name: 'draw-ramrod', duration: 0.5 },
                { name: 'ram-charge', duration: 1.5 },
                { name: 'return-ramrod', duration: 0.5 },
                { name: 'full-cock', duration: 0.5 },
                { name: 'ready', duration: 0 }
            ],
            sightFOV: 20,
            hipFOV: 70,
            aimTransitionSpeed: 0.12
        };

        // Input handling
        const keys = {};
        const playerKeys = {
            p1: { forward: 'w', back: 's', left: 'a', right: 'd', aim: 'q', fire: 'e', reload: 'r' },
            p2: { forward: 'i', back: 'k', left: 'j', right: 'l', aim: 'u', fire: 'o', reload: 'p' }
        };

        document.addEventListener('keydown', (e) => { keys[e.key.toLowerCase()] = true; });
        document.addEventListener('keyup', (e) => { keys[e.key.toLowerCase()] = false; });

        // ============================================
        // FLINTLOCK MUSKET CLASS
        // ============================================
        class FlintlockMusket {
            constructor(scene, playerId) {
                this.scene = scene;
                this.playerId = playerId;
                this.state = 'ready';
                this.loaded = false;
                this.primed = false;
                this.cocked = false;
                this.reloadStageIndex = 0;
                this.reloadTimer = 0;
                
                // Local position offsets relative to camera
                this.hipPos = new THREE.Vector3(0.25, -0.3, 0.6);
                this.hipRot = new THREE.Euler(0.15, -0.3, 0);
                this.aimPos = new THREE.Vector3(0, -0.12, 0.3);
                this.aimRot = new THREE.Euler(0, 0, 0);
                
                this.currentPos = this.hipPos.clone();
                this.currentRot = this.hipRot.clone();
                
                this.createWeaponModel();
            }

            createWeaponModel() {
                this.group = new THREE.Group();
                
                const metalMat = new THREE.MeshStandardMaterial({ 
                    color: 0x444444, 
                    roughness: 0.4, 
                    metalness: 0.8 
                });
                const woodMat = new THREE.MeshStandardMaterial({ 
                    color: 0x654321, 
                    roughness: 0.8 
                });

                // Barrel
                const barrelGeo = new THREE.CylinderGeometry(0.025, 0.03, 1.2, 12);
                this.barrel = new THREE.Mesh(barrelGeo, metalMat);
                this.barrel.rotation.x = Math.PI / 2;
                this.barrel.position.z = 0.6;
                this.group.add(this.barrel);

                // Stock
                const stockGeo = new THREE.BoxGeometry(0.1, 0.12, 0.7);
                this.stock = new THREE.Mesh(stockGeo, woodMat);
                this.stock.position.set(0, -0.04, -0.15);
                this.group.add(this.stock);

                // Buttplate
                const buttGeo = new THREE.BoxGeometry(0.12, 0.14, 0.05);
                const butt = new THREE.Mesh(buttGeo, metalMat);
                butt.position.set(0, -0.04, -0.52);
                this.group.add(butt);

                // Rear sight (notch) - V shaped
                const rearSightGeo = new THREE.BoxGeometry(0.035, 0.025, 0.015);
                this.rearSight = new THREE.Mesh(rearSightGeo, metalMat);
                this.rearSight.position.set(0, 0.075, 0.15);
                this.group.add(this.rearSight);

                // Front sight post
                const frontSightGeo = new THREE.BoxGeometry(0.012, 0.035, 0.008);
                this.frontSight = new THREE.Mesh(frontSightGeo, metalMat);
                this.frontSight.position.set(0, 0.065, 1.18);
                this.group.add(this.frontSight);

                // Lock mechanism (frizzen area)
                const lockGeo = new THREE.BoxGeometry(0.06, 0.08, 0.12);
                this.lock = new THREE.Mesh(lockGeo, metalMat);
                this.lock.position.set(0.07, 0.02, 0.1);
                this.group.add(this.lock);

                // Hammer
                const hammerGeo = new THREE.BoxGeometry(0.02, 0.06, 0.04);
                this.hammer = new THREE.Mesh(hammerGeo, metalMat);
                this.hammer.position.set(0.09, 0.08, 0.05);
                this.group.add(this.hammer);

                // Pan
                const panGeo = new THREE.BoxGeometry(0.025, 0.015, 0.035);
                this.pan = new THREE.Mesh(panGeo, new THREE.MeshStandardMaterial({ color: 0x1a1a1a }));
                this.pan.position.set(0.07, 0.07, 0.1);
                this.group.add(this.pan);

                // Ramrod (stored position)
                const ramrodGeo = new THREE.CylinderGeometry(0.004, 0.004, 0.85, 8);
                this.ramrod = new THREE.Mesh(ramrodGeo, metalMat);
                this.ramrod.rotation.x = Math.PI / 2;
                this.ramrod.position.set(0.05, -0.06, 0.25);
                this.group.add(this.ramrod);

                // Trigger guard
                const guardGeo = new THREE.TorusGeometry(0.04, 0.005, 6, 12, Math.PI);
                this.triggerGuard = new THREE.Mesh(guardGeo, metalMat);
                this.triggerGuard.rotation.z = Math.PI;
                this.triggerGuard.position.set(0, -0.06, 0.02);
                this.group.add(this.triggerGuard);

                // Trigger
                const triggerGeo = new THREE.BoxGeometry(0.008, 0.03, 0.015);
                this.trigger = new THREE.Mesh(triggerGeo, metalMat);
                this.trigger.position.set(0, -0.05, 0.02);
                this.group.add(this.trigger);

                this.scene.add(this.group);
            }

            update(delta, cameraPosition, cameraRotation, isAiming) {
                // Handle reload state machine
                if (this.state !== 'ready') {
                    this.reloadTimer += delta;
                    const currentStage = GAME_CONFIG.reloadStages[this.reloadStageIndex];
                    
                    if (this.reloadTimer >= currentStage.duration) {
                        this.reloadTimer = 0;
                        this.reloadStageIndex++;
                        
                        if (this.reloadStageIndex >= GAME_CONFIG.reloadStages.length) {
                            this.completeReload();
                        }
                    }
                }

                // Animate ramrod during reload
                if (this.state !== 'ready' && this.reloadStageIndex >= 5 && this.reloadStageIndex <= 7) {
                    // Ramrod out
                    this.ramrod.position.x = 0.15;
                    this.ramrod.position.y = -0.02;
                    this.ramrod.rotation.z = -0.3;
                } else {
                    // Ramrod stored
                    this.ramrod.position.set(0.05, -0.06, 0.25);
                    this.ramrod.rotation.z = 0;
                    this.ramrod.rotation.x = Math.PI / 2;
                }

                // Lerp to target position
                const targetPos = isAiming ? this.aimPos : this.hipPos;
                const targetRot = isAiming ? this.aimRot : this.hipRot;

                this.currentPos.lerp(targetPos, GAME_CONFIG.aimTransitionSpeed);
                this.currentRot.x += (targetRot.x - this.currentRot.x) * GAME_CONFIG.aimTransitionSpeed;
                this.currentRot.y += (targetRot.y - this.currentRot.y) * GAME_CONFIG.aimTransitionSpeed;
                this.currentRot.z += (targetRot.z - this.currentRot.z) * GAME_CONFIG.aimTransitionSpeed;

                // Apply to group - set absolute position relative to world
                this.group.position.copy(cameraPosition);
                this.group.rotation.setFromQuaternion(cameraRotation);
                
                // Apply local offsets
                const offset = this.currentPos.clone().applyQuaternion(cameraRotation);
                this.group.position.add(offset);
                
                this.group.rotateX(this.currentRot.x);
                this.group.rotateY(this.currentRot.y);
                this.group.rotateZ(this.currentRot.z);
            }

            startReload() {
                if (this.state !== 'ready' || this.loaded) return false;
                this.state = 'reloading';
                this.reloadStageIndex = 0;
                this.reloadTimer = 0;
                this.primed = false;
                this.cocked = false;
                return true;
            }

            completeReload() {
                this.state = 'ready';
                this.loaded = true;
                this.primed = true;
                this.cocked = true;
                this.reloadStageIndex = 0;
            }

            fire() {
                if (!this.loaded || !this.cocked || this.state !== 'ready') {
                    return null;
                }

                this.loaded = false;
                this.primed = false;
                this.cocked = false;

                // Get muzzle world position
                const muzzleOffset = new THREE.Vector3(0, 0.065, 1.25);
                muzzleOffset.applyQuaternion(this.group.quaternion);
                const muzzlePos = this.group.position.clone().add(muzzleOffset);
                
                // Get barrel direction
                const direction = new THREE.Vector3(0, 0, 1);
                direction.applyQuaternion(this.group.quaternion);
                direction.normalize();

                return { position: muzzlePos, direction: direction };
            }

            getReloadStatus() {
                if (this.state === 'ready') return this.loaded ? 'READY' : 'EMPTY';
                return GAME_CONFIG.reloadStages[this.reloadStageIndex].name.toUpperCase();
            }
        }

        // ============================================
        // PROJECTILE / BALLISTICS
        // ============================================
        class ProjectileManager {
            constructor(scene) {
                this.scene = scene;
                this.projectiles = [];
                
                const ballGeo = new THREE.SphereGeometry(0.018, 8, 8);
                const ballMat = new THREE.MeshStandardMaterial({ color: 0x111111 });
                this.ballGeometry = ballGeo;
                this.ballMaterial = ballMat;
                
                // Tracers
                this.tracers = [];
            }

            spawn(position, direction, ownerId) {
                const mesh = new THREE.Mesh(this.ballGeometry, this.ballMaterial);
                mesh.position.copy(position);
                this.scene.add(mesh);

                this.projectiles.push({
                    mesh: mesh,
                    velocity: direction.clone().multiplyScalar(GAME_CONFIG.musketVelocity),
                    owner: ownerId,
                    life: 4.0
                });
            }

            update(delta, players) {
                for (let i = this.projectiles.length - 1; i >= 0; i--) {
                    const proj = this.projectiles[i];
                    proj.life -= delta;

                    // Apply gravity
                    proj.velocity.y -= GAME_CONFIG.gravity * delta;

                    // Move projectile
                    const moveStep = proj.velocity.clone().multiplyScalar(delta);
                    proj.mesh.position.add(moveStep);

                    // Check collisions with players
                    let hit = false;
                    for (const player of players) {
                        if (player.id !== proj.owner && player.alive) {
                            const dist = proj.mesh.position.distanceTo(player.position);
                            if (dist < 0.6) {
                                player.takeDamage(100);
                                hit = true;
                                break;
                            }
                        }
                    }

                    // Remove if hit, expired, or below ground
                    if (hit || proj.life <= 0 || proj.mesh.position.y < -1) {
                        this.scene.remove(proj.mesh);
                        this.projectiles.splice(i, 1);
                    }
                }
            }
        }

        // ============================================
        // PLAYER CLASS
        // ============================================
        class Player {
            constructor(id, startPos, keyMap) {
                this.id = id;
                this.position = startPos.clone();
                this.rotation = id === 1 ? 0 : Math.PI;
                this.health = 100;
                this.alive = true;
                this.keyMap = keyMap;
                this.isAiming = false;
                
                this.camera = new THREE.PerspectiveCamera(
                    GAME_CONFIG.hipFOV, 
                    0.5, 
                    0.1, 
                    500
                );
                this.cameraQuaternion = new THREE.Quaternion();
                
                this.respawnTimer = 0;
                this.respawnDelay = 3;
            }

            init(scene) {
                this.musket = new FlintlockMusket(scene, this.id);
                this.updateCamera();
            }

            update(delta, scene, allPlayers) {
                if (!this.alive) {
                    this.respawnTimer -= delta;
                    if (this.respawnTimer <= 0) {
                        this.respawn();
                    }
                    return;
                }

                const k = this.keyMap;
                
                // Movement input
                let moveForward = 0;
                let turn = 0;

                if (keys[k.forward]) moveForward += 1;
                if (keys[k.back]) moveForward -= 1;
                if (keys[k.left]) turn += 1;
                if (keys[k.right]) turn -= 1;

                // Rotation
                this.rotation += turn * GAME_CONFIG.turnSpeed;

                // Forward/back movement (no strafing - period accurate)
                const speed = this.isAiming ? GAME_CONFIG.walkSpeed * 0.2 : GAME_CONFIG.walkSpeed;
                const moveDist = moveForward * speed * delta;
                
                // Calculate new position
                const newX = this.position.x + Math.sin(this.rotation) * moveDist;
                const newZ = this.position.z + Math.cos(this.rotation) * moveDist;
                
                // Keep in bounds and check collisions with other players
                let canMove = true;
                for (const other of allPlayers) {
                    if (other !== this && other.alive) {
                        const dx = newX - other.position.x;
                        const dz = newZ - other.position.z;
                        const dist = Math.sqrt(dx*dx + dz*dz);
                        if (dist < 1.0) {
                            canMove = false;
                            break;
                        }
                    }
                }
                
                if (canMove) {
                    this.position.x = Math.max(-48, Math.min(48, newX));
                    this.position.z = Math.max(-48, Math.min(48, newZ));
                }

                // Aiming toggle
                this.isAiming = keys[k.aim];

                // Update camera FOV
                const targetFOV = this.isAiming ? GAME_CONFIG.sightFOV : GAME_CONFIG.hipFOV;
                this.camera.fov += (targetFOV - this.camera.fov) * GAME_CONFIG.aimTransitionSpeed;
                this.camera.updateProjectionMatrix();

                // Update camera transform
                this.updateCamera();
                
                // Update musket
                this.musket.update(delta, this.camera.position, this.cameraQuaternion, this.isAiming);
            }

            updateCamera() {
                this.camera.position.copy(this.position);
                this.camera.position.y = 1.65;
                
                // Build rotation quaternion
                const euler = new THREE.Euler(
                    this.isAiming ? -0.015 : 0, // Slight pitch down when aiming
                    this.rotation,
                    0,
                    'YXZ'
                );
                this.cameraQuaternion.setFromEuler(euler);
                this.camera.quaternion.copy(this.cameraQuaternion);
            }

            fire() {
                return this.musket.fire();
            }

            takeDamage(amount) {
                this.health -= amount;
                if (this.health <= 0) {
                    this.alive = false;
                    this.health = 0;
                    this.respawnTimer = this.respawnDelay;
                }
            }

            respawn() {
                this.alive = true;
                this.health = 100;
                this.position.set(
                    this.id === 1 ? -15 : 15,
                    0,
                    (Math.random() - 0.5) * 20
                );
                this.rotation = this.id === 1 ? 0 : Math.PI;
            }
        }

        // ============================================
        // MAIN GAME
        // ============================================
        class Game {
            constructor() {
                this.scene = new THREE.Scene();
                this.scene.background = new THREE.Color(0x7ba3c9);
                this.scene.fog = new THREE.Fog(0x7ba3c9, 30, 120);

                this.renderer = new THREE.WebGLRenderer({ antialias: true });
                this.renderer.setSize(window.innerWidth, window.innerHeight);
                this.renderer.shadowMap.enabled = true;
                this.renderer.shadowMap.type = THREE.PCFSoftShadowMap;
                document.getElementById('gameContainer').appendChild(this.renderer.domElement);

                // Lighting
                const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
                this.scene.add(ambientLight);

                const dirLight = new THREE.DirectionalLight(0xffffff, 0.7);
                dirLight.position.set(60, 100, 40);
                dirLight.castShadow = true;
                dirLight.shadow.camera.left = -60;
                dirLight.shadow.camera.right = 60;
                dirLight.shadow.camera.top = 60;
                dirLight.shadow.camera.bottom = -60;
                dirLight.shadow.camera.far = 200;
                dirLight.shadow.mapSize.width = 2048;
                dirLight.shadow.mapSize.height = 2048;
                this.scene.add(dirLight);

                // Environment
                this.createEnvironment();

                // Players
                this.player1 = new Player(1, new THREE.Vector3(-15, 0, 0), playerKeys.p1);
                this.player2 = new Player(2, new THREE.Vector3(15, 0, 0), playerKeys.p2);
                this.players = [this.player1, this.player2];
                
                this.player1.init(this.scene);
                this.player2.init(this.scene);

                // Projectiles
                this.projectiles = new ProjectileManager(this.scene);

                // Input timing
                this.lastFireTime = { p1: 0, p2: 0 };
                this.fireCooldown = 0.5;

                // Handle resize
                window.addEventListener('resize', () => this.onWindowResize());

                // Start
                this.clock = new THREE.Clock();
                this.onWindowResize();
                this.animate();
            }

            createEnvironment() {
                // Ground with terrain variation
                const groundGeo = new THREE.PlaneGeometry(100, 100, 20, 20);
                const groundMat = new THREE.MeshStandardMaterial({ 
                    color: 0x4a5d4a,
                    roughness: 0.9,
                    flatShading: true
                });
                
                // Add slight height variation
                const posAttr = groundGeo.attributes.position;
                for (let i = 0; i < posAttr.count; i++) {
                    const x = posAttr.getX(i);
                    const y = posAttr.getY(i);
                    const z = Math.sin(x * 0.1) * Math.cos(y * 0.1) * 0.5;
                    posAttr.setZ(i, z);
                }
                groundGeo.computeVertexNormals();
                
                const ground = new THREE.Mesh(groundGeo, groundMat);
                ground.rotation.x = -Math.PI / 2;
                ground.receiveShadow = true;
                this.scene.add(ground);

                // Trees
                for (let i = 0; i < 15; i++) {
                    const x = (Math.random() - 0.5) * 80;
                    const z = (Math.random() - 0.5) * 80;
                    // Don't place near spawn points
                    if (Math.abs(x) > 12 || Math.abs(z) > 10) {
                        this.createTree(x, z);
                    }
                }

                // Barricades / Cover
                for (let i = 0; i < 10; i++) {
                    const x = (Math.random() - 0.5) * 60;
                    const z = (Math.random() - 0.5) * 60;
                    if (Math.abs(x) > 8 || Math.abs(z) > 8) {
                        this.createBarricade(x, z);
                    }
                }
                
                // Rock formations
                for (let i = 0; i < 6; i++) {
                    const x = (Math.random() - 0.5) * 70;
                    const z = (Math.random() - 0.5) * 70;
                    if (Math.abs(x) > 10 || Math.abs(z) > 10) {
                        this.createRock(x, z);
                    }
                }
            }

            createTree(x, z) {
                const trunkGeo = new THREE.CylinderGeometry(0.25, 0.35, 2.5, 8);
                const trunkMat = new THREE.MeshStandardMaterial({ color: 0x3d2817 });
                const trunk = new THREE.Mesh(trunkGeo, trunkMat);
                trunk.position.set(x, 1.25, z);
                trunk.castShadow = true;
                trunk.receiveShadow = true;
                this.scene.add(trunk);

                const leavesGeo = new THREE.ConeGeometry(2.5, 5, 8);
                const leavesMat = new THREE.MeshStandardMaterial({ color: 0x1a3d0a });
                const leaves = new THREE.Mesh(leavesGeo, leavesMat);
                leaves.position.set(x, 4.5, z);
                leaves.castShadow = true;
                this.scene.add(leaves);
            }

            createBarricade(x, z) {
                const width = 2 + Math.random() * 2;
                const geo = new THREE.BoxGeometry(width, 1.8, 0.4);
                const mat = new THREE.MeshStandardMaterial({ color: 0x4a3728 });
                const barricade = new THREE.Mesh(geo, mat);
                barricade.position.set(x, 0.9, z);
                barricade.rotation.y = Math.random() * Math.PI;
                barricade.castShadow = true;
                barricade.receiveShadow = true;
                this.scene.add(barricade);
            }
            
            createRock(x, z) {
                const size = 0.8 + Math.random() * 1.5;
                const geo = new THREE.DodecahedronGeometry(size, 0);
                const mat = new THREE.MeshStandardMaterial({ 
                    color: 0x666666,
                    roughness: 0.9,
                    flatShading: true
                });
                const rock = new THREE.Mesh(geo, mat);
                rock.position.set(x, size * 0.4, z);
                rock.rotation.set(Math.random(), Math.random(), Math.random());
                rock.castShadow = true;
                rock.receiveShadow = true;
                this.scene.add(rock);
            }

            onWindowResize() {
                const width = window.innerWidth;
                const height = window.innerHeight;
                
                this.renderer.setSize(width, height);
                
                const aspect = (width / 2) / height;
                this.player1.camera.aspect = aspect;
                this.player2.camera.aspect = aspect;
                this.player1.camera.updateProjectionMatrix();
                this.player2.camera.updateProjectionMatrix();
            }

            checkInput(delta) {
                const now = this.clock.getElapsedTime();

                // Player 1 Fire
                if (keys[this.player1.keyMap.fire] && now - this.lastFireTime.p1 > this.fireCooldown) {
                    const fireData = this.player1.fire();
                    if (fireData) {
                        this.projectiles.spawn(fireData.position, fireData.direction, 1);
                        this.lastFireTime.p1 = now;
                        
                        // Flash effect
                        this.createMuzzleFlash(fireData.position);
                    }
                }

                // Player 1 Reload
                if (keys[this.player1.keyMap.reload]) {
                    this.player1.musket.startReload();
                }

                // Player 2 Fire
                if (keys[this.player2.keyMap.fire] && now - this.lastFireTime.p2 > this.fireCooldown) {
                    const fireData = this.player2.fire();
                    if (fireData) {
                        this.projectiles.spawn(fireData.position, fireData.direction, 2);
                        this.lastFireTime.p2 = now;
                        this.createMuzzleFlash(fireData.position);
                    }
                }

                // Player 2 Reload
                if (keys[this.player2.keyMap.reload]) {
                    this.player2.musket.startReload();
                }
            }
            
            createMuzzleFlash(position) {
                const flashGeo = new THREE.SphereGeometry(0.15, 8, 8);
                const flashMat = new THREE.MeshBasicMaterial({ 
                    color: 0xffaa00,
                    transparent: true,
                    opacity: 0.8
                });
                const flash = new THREE.Mesh(flashGeo, flashMat);
                flash.position.copy(position);
                this.scene.add(flash);
                
                // Smoke
                const smokeGeo = new THREE.SphereGeometry(0.1, 6, 6);
                const smokeMat = new THREE.MeshBasicMaterial({
                    color: 0x888888,
                    transparent: true,
                    opacity: 0.5
                });
                const smoke = new THREE.Mesh(smokeGeo, smokeMat);
                smoke.position.copy(position);
                this.scene.add(smoke);
                
                // Animate and remove
                let life = 0.2;
                const animate = () => {
                    life -= 0.016;
                    if (life <= 0) {
                        this.scene.remove(flash);
                        this.scene.remove(smoke);
                        return;
                    }
                    flash.scale.multiplyScalar(0.9);
                    flash.material.opacity = life * 4;
                    smoke.scale.multiplyScalar(1.05);
                    smoke.position.y += 0.02;
                    smoke.material.opacity *= 0.95;
                    requestAnimationFrame(animate);
                };
                animate();
            }

            animate() {
                requestAnimationFrame(() => this.animate());

                const delta = Math.min(this.clock.getDelta(), 0.1);

                // Update players
                this.player1.update(delta, this.scene, this.players);
                this.player2.update(delta, this.scene, this.players);

                // Check input
                this.checkInput(delta);

                // Update projectiles
                this.projectiles.update(delta, this.players);

                // Render split screen
                const width = this.renderer.domElement.width;
                const height = this.renderer.domElement.height;

                this.renderer.setScissorTest(true);

                // Player 1 viewport (left)
                this.renderer.setScissor(0, 0, width / 2, height);
                this.renderer.setViewport(0, 0, width / 2, height);
                this.renderer.render(this.scene, this.player1.camera);

                // Player 2 viewport (right)
                this.renderer.setScissor(width / 2, 0, width / 2, height);
                this.renderer.setViewport(width / 2, 0, width / 2, height);
                this.renderer.render(this.scene, this.player2.camera);

                this.renderer.setScissorTest(false);
            }
        }

        // Initialize
        window.addEventListener('load', () => {
            new Game();
        });
    </script>
</body>
</html>