<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A Musketeer Duel</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: #000;
            overflow: hidden;
            font-family: Georgia, serif;
        }
        #game-container {
            display: flex;
            width: 100vw;
            height: 100vh;
        }
        .player-view {
            flex: 1;
            position: relative;
            border: 2px solid #3a2a1a;
        }
        .player-view:first-child {
            border-right: 4px solid #2a1a0a;
        }
        canvas {
            display: block;
        }
        .hud {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            color: #d4af37;
            text-align: center;
            font-size: 14px;
            text-shadow: 2px 2px 4px #000;
            pointer-events: none;
        }
        .reload-status {
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            color: #ff6b6b;
            font-size: 16px;
            font-weight: bold;
            text-shadow: 2px 2px 4px #000;
            display: none;
        }
        .controls {
            position: absolute;
            top: 10px;
            font-size: 11px;
            color: #8a7a5a;
            text-shadow: 1px 1px 2px #000;
        }
        .p1-controls { left: 10px; text-align: left; }
        .p2-controls { right: 10px; text-align: right; }
        #title {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #d4af37;
            font-size: 48px;
            text-shadow: 3px 3px 6px #000;
            text-align: center;
            z-index: 100;
        }
        #start-btn {
            margin-top: 20px;
            padding: 15px 40px;
            font-size: 20px;
            background: #3a2a1a;
            color: #d4af37;
            border: 2px solid #d4af37;
            cursor: pointer;
            font-family: Georgia, serif;
        }
        #start-btn:hover {
            background: #d4af37;
            color: #3a2a1a;
        }
    </style>
</head>
<body>
    <div id="title">
        <div>A MUSKETEER DUEL</div>
        <button id="start-btn">ENGAGE</button>
    </div>
    <div id="game-container" style="display: none;">
        <div class="player-view" id="p1-view">
            <div class="controls p1-controls">
                P1: WASD Move | Q/E Turn Musket | X Aim | F Fire | R Reload
            </div>
            <div class="reload-status" id="p1-reload"></div>
            <div class="hud" id="p1-hud">Ready</div>
        </div>
        <div class="player-view" id="p2-view">
            <div class="controls p2-controls">
                P2: IJKL Move | U/O Turn Musket | M Aim | ; Fire | P Reload
            </div>
            <div class="reload-status" id="p2-reload"></div>
            <div class="hud" id="p2-hud">Ready</div>
        </div>
    </div>

    <script type="importmap">
    {
        "imports": {
            "three": "https://unpkg.com/three@0.160.0/build/three.module.js"
        }
    }
    </script>
    <script type="module">
        import * as THREE from 'three';

        // Game state
        const gameState = {
            started: false,
            p1: { health: 100, ammo: 1, reloading: false, aiming: false, musketAngle: 0 },
            p2: { health: 100, ammo: 1, reloading: false, aiming: false, musketAngle: 0 }
        };

        // Reload steps for authentic flintlock sequence
        const RELOAD_STEPS = [
            { name: "Half-cock", duration: 400 },
            { name: "Prime pan", duration: 600 },
            { name: "Shut pan", duration: 300 },
            { name: "Cast about", duration: 400 },
            { name: "Charge main", duration: 800 },
            { name: "Draw rammer", duration: 500 },
            { name: "Ram cartridge", duration: 1000 },
            { name: "Return rammer", duration: 600 },
            { name: "Full cock", duration: 400 }
        ];

        // Input handling
        const keys = {};
        const PLAYER1_KEYS = { w: false, a: false, s: false, d: false, q: false, e: false, x: false, f: false, r: false };
        const PLAYER2_KEYS = { i: false, j: false, k: false, l: false, u: false, o: false, m: false, semicolon: false, p: false };

        window.addEventListener('keydown', (e) => {
            const key = e.key.toLowerCase();
            keys[key] = true;
            if (key === ';') keys.semicolon = true;
        });

        window.addEventListener('keyup', (e) => {
            const key = e.key.toLowerCase();
            keys[key] = false;
            if (key === ';') keys.semicolon = false;
        });

        // Three.js setup
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x87CEEB);
        scene.fog = new THREE.Fog(0x87CEEB, 10, 100);

        // Ground
        const groundGeometry = new THREE.PlaneGeometry(200, 200);
        const groundMaterial = new THREE.MeshLambertMaterial({ color: 0x3a4a3a });
        const ground = new THREE.Mesh(groundGeometry, groundMaterial);
        ground.rotation.x = -Math.PI / 2;
        scene.add(ground);

        // Add some terrain features
        for (let i = 0; i < 20; i++) {
            const rock = new THREE.Mesh(
                new THREE.DodecahedronGeometry(Math.random() * 2 + 0.5),
                new THREE.MeshLambertMaterial({ color: 0x5a5a5a })
            );
            rock.position.set(
                (Math.random() - 0.5) * 80,
                Math.random() * 1,
                (Math.random() - 0.5) * 80
            );
            scene.add(rock);
        }

        // Trees
        for (let i = 0; i < 15; i++) {
            const trunk = new THREE.Mesh(
                new THREE.CylinderGeometry(0.3, 0.4, 3),
                new THREE.MeshLambertMaterial({ color: 0x4a3728 })
            );
            const leaves = new THREE.Mesh(
                new THREE.ConeGeometry(3, 8),
                new THREE.MeshLambertMaterial({ color: 0x2a5a2a })
            );
            trunk.position.set((Math.random() - 0.5) * 90, 1.5, (Math.random() - 0.5) * 90);
            leaves.position.copy(trunk.position);
            leaves.position.y += 5.5;
            scene.add(trunk, leaves);
        }

        // Lighting
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
        scene.add(ambientLight);
        const dirLight = new THREE.DirectionalLight(0xffffff, 0.8);
        dirLight.position.set(50, 100, 50);
        scene.add(dirLight);

        // Create musket with iron sights
        function createMusket() {
            const musketGroup = new THREE.Group();

            // Stock
            const stock = new THREE.Mesh(
                new THREE.BoxGeometry(0.12, 0.2, 1.2),
                new THREE.MeshLambertMaterial({ color: 0x4a3728 })
            );
            stock.position.set(0, -0.1, 0.2);
            musketGroup.add(stock);

            // Barrel
            const barrel = new THREE.Mesh(
                new THREE.CylinderGeometry(0.03, 0.03, 1.4),
                new THREE.MeshLambertMaterial({ color: 0x2a2a2a })
            );
            barrel.rotation.x = Math.PI / 2;
            barrel.position.set(0, 0.05, 0.3);
            musketGroup.add(barrel);

            // Rear sight (notch)
            const rearSight = new THREE.Mesh(
                new THREE.BoxGeometry(0.02, 0.04, 0.02),
                new THREE.MeshLambertMaterial({ color: 0x1a1a1a })
            );
            rearSight.position.set(0, 0.15, -0.3);
            musketGroup.add(rearSight);

            // Rear sight notch (V-shaped cut visible)
            const rearNotchL = new THREE.Mesh(
                new THREE.BoxGeometry(0.01, 0.03, 0.015),
                new THREE.MeshLambertMaterial({ color: 0x1a1a1a })
            );
            rearNotchL.position.set(-0.008, 0.13, -0.3);
            rearNotchL.rotation.z = -0.3;
            musketGroup.add(rearNotchL);

            const rearNotchR = new THREE.Mesh(
                new THREE.BoxGeometry(0.01, 0.03, 0.015),
                new THREE.MeshLambertMaterial({ color: 0x1a1a1a })
            );
            rearNotchR.position.set(0.008, 0.13, -0.3);
            rearNotchR.rotation.z = 0.3;
            musketGroup.add(rearNotchR);

            // Front sight post
            const frontSight = new THREE.Mesh(
                new THREE.BoxGeometry(0.01, 0.04, 0.01),
                new THREE.MeshLambertMaterial({ color: 0x1a1a1a })
            );
            frontSight.position.set(0, 0.14, 0.9);
            musketGroup.add(frontSight);

            // Flintlock mechanism
            const lockPlate = new THREE.Mesh(
                new THREE.BoxGeometry(0.08, 0.15, 0.2),
                new THREE.MeshLambertMaterial({ color: 0x3a3a3a })
            );
            lockPlate.position.set(0.08, 0.05, -0.1);
            musketGroup.add(lockPlate);

            // Hammer
            const hammer = new THREE.Mesh(
                new THREE.BoxGeometry(0.02, 0.08, 0.08),
                new THREE.MeshLambertMaterial({ color: 0x2a2a2a })
            );
            hammer.position.set(0.12, 0.15, -0.15);
            hammer.rotation.z = -0.5;
            musketGroup.add(hammer);

            // Ramrod
            const ramrod = new THREE.Mesh(
                new THREE.CylinderGeometry(0.008, 0.008, 1.2),
                new THREE.MeshLambertMaterial({ color: 0x5a5a5a })
            );
            ramrod.rotation.x = Math.PI / 2;
            ramrod.position.set(0.06, -0.12, 0.3);
            musketGroup.add(ramrod);

            return musketGroup;
        }

        // Players
        const p1Musket = createMusket();
        const p2Musket = createMusket();

        // Player cameras
        const p1Camera = new THREE.PerspectiveCamera(75, window.innerWidth / 2 / window.innerHeight, 0.1, 1000);
        const p2Camera = new THREE.PerspectiveCamera(75, window.innerWidth / 2 / window.innerHeight, 0.1, 1000);

        // Player positions
        const p1Pos = new THREE.Vector3(-20, 1.6, 0);
        const p2Pos = new THREE.Vector3(20, 1.6, 0);
        let p1Rotation = 0;
        let p2Rotation = Math.PI;

        // Renderers
        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setScissorTest(true);
        document.getElementById('p1-view').appendChild(renderer.domElement);

        // Bullets
        const bullets = [];

        function fireBullet(player, position, rotation, musketAngle) {
            if (player.ammo <= 0 || player.reloading) return;
            
            player.ammo = 0;
            updateHUD();

            // Calculate firing direction based on musket angle
            const bulletDir = new THREE.Vector3(
                Math.sin(rotation + musketAngle * 0.01) * Math.cos(musketAngle * 0.005),
                Math.sin(musketAngle * 0.005),
                Math.cos(rotation + musketAngle * 0.01) * Math.cos(musketAngle * 0.005)
            );

            const bullet = {
                mesh: new THREE.Mesh(
                    new THREE.SphereGeometry(0.03),
                    new THREE.MeshBasicMaterial({ color: 0x1a1a1a })
                ),
                velocity: bulletDir.multiplyScalar(80),
                position: position.clone(),
                owner: player === gameState.p1 ? 'p1' : 'p2',
                drop: 0
            };
            bullet.mesh.position.copy(position);
            scene.add(bullet.mesh);
            bullets.push(bullet);

            // Flash effect
            const flash = new THREE.PointLight(0xffaa00, 2, 10);
            flash.position.copy(position);
            scene.add(flash);
            setTimeout(() => scene.remove(flash), 50);

            // Recoil animation
            const musket = player === gameState.p1 ? p1Musket : p2Musket;
            musket.rotation.x = 0.3;
            setTimeout(() => musket.rotation.x = 0, 200);
        }

        async function reload(player, musket, hudId) {
            if (player.reloading || player.ammo > 0) return;
            
            player.reloading = true;
            const reloadEl = document.getElementById(hudId === 'p1-hud' ? 'p1-reload' : 'p2-reload');
            reloadEl.style.display = 'block';

            // Animate through each step
            for (const step of RELOAD_STEPS) {
                reloadEl.textContent = step.name;
                
                // Animate musket based on step
                switch(step.name) {
                    case "Half-cock":
                        musket.rotation.z = 0.1;
                        break;
                    case "Prime pan":
                        musket.rotation.x = -0.2;
                        break;
                    case "Charge main":
                        musket.rotation.x = -0.5;
                        break;
                    case "Draw rammer":
                        musket.rotation.x = -0.3;
                        break;
                    case "Ram cartridge":
                        musket.position.z = 0.1;
                        setTimeout(() => musket.position.z = 0, 200);
                        break;
                    case "Return rammer":
                        musket.rotation.x = -0.2;
                        break;
                    case "Full cock":
                        musket.rotation.z = 0;
                        musket.rotation.x = 0;
                        break;
                }
                
                await new Promise(r => setTimeout(r, step.duration));
            }

            player.ammo = 1;
            player.reloading = false;
            reloadEl.style.display = 'none';
            updateHUD();
        }

        function updateHUD() {
            document.getElementById('p1-hud').textContent = 
                gameState.p1.reloading ? 'Reloading...' : 
                gameState.p1.ammo > 0 ? 'Ready to fire' : 'Empty - Reload (R)';
            document.getElementById('p2-hud').textContent = 
                gameState.p2.reloading ? 'Reloading...' : 
                gameState.p2.ammo > 0 ? 'Ready to fire' : 'Empty - Reload (P)';
        }

        // Main game loop
        function update(delta) {
            if (!gameState.started) return;

            const speed = 5 * delta;
            const turnSpeed = 2 * delta;
            const musketTurnSpeed = 1 * delta;

            // Player 1 movement
            if (keys.w) {
                p1Pos.x += Math.sin(p1Rotation) * speed;
                p1Pos.z += Math.cos(p1Rotation) * speed;
            }
            if (keys.s) {
                p1Pos.x -= Math.sin(p1Rotation) * speed;
                p1Pos.z -= Math.cos(p1Rotation) * speed;
            }
            if (keys.a) {
                p1Pos.x += Math.sin(p1Rotation - Math.PI/2) * speed;
                p1Pos.z += Math.cos(p1Rotation - Math.PI/2) * speed;
            }
            if (keys.d) {
                p1Pos.x += Math.sin(p1Rotation + Math.PI/2) * speed;
                p1Pos.z += Math.cos(p1Rotation + Math.PI/2) * speed;
            }
            if (keys.q) {
                p1Rotation += turnSpeed;
            }
            if (keys.e) {
                p1Rotation -= turnSpeed;
            }
            if (keys.arrowleft || keys.q) {
                gameState.p1.musketAngle += musketTurnSpeed * 20;
                gameState.p1.musketAngle = Math.max(-30, Math.min(30, gameState.p1.musketAngle));
            }
            if (keys.arrowright || keys.e) {
                gameState.p1.musketAngle -= musketTurnSpeed * 20;
                gameState.p1.musketAngle = Math.max(-30, Math.min(30, gameState.p1.musketAngle));
            }
            if (keys.x) {
                gameState.p1.aiming = true;
            } else {
                gameState.p1.aiming = false;
            }
            if (keys.f && !gameState.p1.reloading && gameState.p1.ammo > 0) {
                fireBullet(gameState.p1, p1Pos.clone().add(new THREE.Vector3(0, 0.1, 0)), p1Rotation, gameState.p1.musketAngle);
                keys.f = false;
            }
            if (keys.r && !gameState.p1.reloading) {
                reload(gameState.p1, p1Musket, 'p1-hud');
            }

            // Player 2 movement (IJKL + UO)
            if (keys.i) {
                p2Pos.x += Math.sin(p2Rotation) * speed;
                p2Pos.z += Math.cos(p2Rotation) * speed;
            }
            if (keys.k) {
                p2Pos.x -= Math.sin(p2Rotation) * speed;
                p2Pos.z -= Math.cos(p2Rotation) * speed;
            }
            if (keys.j) {
                p2Pos.x += Math.sin(p2Rotation - Math.PI/2) * speed;
                p2Pos.z += Math.cos(p2Rotation - Math.PI/2) * speed;
            }
            if (keys.l) {
                p2Pos.x += Math.sin(p2Rotation + Math.PI/2) * speed;
                p2Pos.z += Math.cos(p2Rotation + Math.PI/2) * speed;
            }
            if (keys.u) {
                p2Rotation += turnSpeed;
            }
            if (keys.o) {
                p2Rotation -= turnSpeed;
            }
            if (keys.arrowleft || keys.u) {
                gameState.p2.musketAngle += musketTurnSpeed * 20;
                gameState.p2.musketAngle = Math.max(-30, Math.min(30, gameState.p2.musketAngle));
            }
            if (keys.arrowright || keys.o) {
                gameState.p2.musketAngle -= musketTurnSpeed * 20;
                gameState.p2.musketAngle = Math.max(-30, Math.min(30, gameState.p2.musketAngle));
            }
            if (keys.m) {
                gameState.p2.aiming = true;
            } else {
                gameState.p2.aiming = false;
            }
            if ((keys.semicolon || keys[';']) && !gameState.p2.reloading && gameState.p2.ammo > 0) {
                fireBullet(gameState.p2, p2Pos.clone().add(new THREE.Vector3(0, 0.1, 0)), p2Rotation, gameState.p2.musketAngle);
                keys.semicolon = false;
                keys[';'] = false;
            }
            if (keys.p && !gameState.p2.reloading) {
                reload(gameState.p2, p2Musket, 'p2-hud');
            }

            // Update cameras
            p1Camera.position.copy(p1Pos);
            p1Camera.rotation.y = p1Rotation;
            p1Camera.rotation.x = gameState.p1.musketAngle * 0.01;

            p2Camera.position.copy(p2Pos);
            p2Camera.rotation.y = p2Rotation;
            p2Camera.rotation.x = gameState.p2.musketAngle * 0.01;

            // Update musket positions (visible in lower right)
            p1Musket.position.copy(p1Pos);
            p1Musket.rotation.y = p1Rotation + gameState.p1.musketAngle * 0.01;
            p1Musket.position.x += Math.sin(p1Rotation) * 0.3 + 0.15;
            p1Musket.position.y = 1.3;
            p1Musket.position.z += Math.cos(p1Rotation) * 0.3;

            p2Musket.position.copy(p2Pos);
            p2Musket.rotation.y = p2Rotation + gameState.p2.musketAngle * 0.01;
            p2Musket.position.x += Math.sin(p2Rotation) * 0.3 + 0.15;
            p2Musket.position.y = 1.3;
            p2Musket.position.z += Math.cos(p2Rotation) * 0.3;

            // Update bullets with drop
            for (let i = bullets.length - 1; i >= 0; i--) {
                const b = bullets[i];
                b.drop += 9.8 * delta * delta;
                b.velocity.y -= 9.8 * delta * 0.1;
                b.mesh.position.add(b.velocity.clone().multiplyScalar(delta));
                b.mesh.position.y -= b.drop;

                // Remove if too low or far
                if (b.mesh.position.y < 0 || b.mesh.position.distanceTo(p1Pos) > 200) {
                    scene.remove(b.mesh);
                    bullets.splice(i, 1);
                    continue;
                }

                // Check hits
                const p1Hit = b.mesh.position.distanceTo(p1Pos) < 1 && b.owner === 'p2';
                const p2Hit = b.mesh.position.distanceTo(p2Pos) < 1 && b.owner === 'p1';

                if (p1Hit) {
                    gameState.p1.health -= 50;
                    scene.remove(b.mesh);
                    bullets.splice(i, 1);
                    if (gameState.p1.health <= 0) {
                        alert('Player 2 Wins!');
                        location.reload();
                    }
                } else if (p2Hit) {
                    gameState.p2.health -= 50;
                    scene.remove(b.mesh);
                    bullets.splice(i, 1);
                    if (gameState.p2.health <= 0) {
                        alert('Player 1 Wins!');
                        location.reload();
                    }
                }
            }

            // Clamp positions to ground
            p1Pos.y = 1.6;
            p2Pos.y = 1.6;
        }

        function render() {
            const width = window.innerWidth / 2;
            const height = window.innerHeight;

            // Player 1 viewport (left half)
            renderer.setScissor(0, 0, width, height);
            renderer.setViewport(0, 0, width, height);
            renderer.render(scene, p1Camera);

            // Player 2 viewport (right half)
            renderer.setScissor(width, 0, width, height);
            renderer.setViewport(width, 0, width, height);
            renderer.render(scene, p2Camera);
        }

        // Animation loop
        let lastTime = 0;
        function animate(time) {
            const delta = (time - lastTime) / 1000;
            lastTime = time;

            update(delta);
            render();
            requestAnimationFrame(animate);
        }

        // Start button
        document.getElementById('start-btn').addEventListener('click', () => {
            document.getElementById('title').style.display = 'none';
            document.getElementById('game-container').style.display = 'flex';
            gameState.started = true;
            
            // Add muskets to scene
            scene.add(p1Musket);
            scene.add(p2Musket);
            
            requestAnimationFrame(animate);
        });

        // Handle resize
        window.addEventListener('resize', () => {
            const aspect = (window.innerWidth / 2) / window.innerHeight;
            p1Camera.aspect = aspect;
            p2Camera.aspect = aspect;
            p1Camera.updateProjectionMatrix();
            p2Camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
</html>
