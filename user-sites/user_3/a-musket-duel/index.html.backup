<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>A Musket Duel</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <div id="game-container">
        <div class="start-screen" id="start-screen">
            <h1>A Musket Duel</h1>
            <p style="opacity: 0.6; margin-bottom: 20px;">Honor. Powder. Steel.</p>
            
            <div class="controls-section">
                <div class="player-controls">
                    <h3>Player 1 (Left)</h3>
                    <p><span class="key">W</span><span class="key">A</span><span class="key">S</span><span class="key">D</span> Move</p>
                    <p><span class="key">Q</span><span class="key">E</span> Tilt Musket</p>
                    <p><span class="key">X</span> Aim (Iron Sights)</p>
                    <p><span class="key">F</span> Fire</p>
                    <p><span class="key">R</span> Reload</p>
                </div>
                <div class="player-controls">
                    <h3>Player 2 (Right)</h3>
                    <p><span class="key">↑</span><span class="key">←</span><span class="key">↓</span><span class="key">→</span> Move</p>
                    <p><span class="key">O</span><span class="key">P</span> Tilt Musket</p>
                    <p><span class="key">M</span> Aim (Iron Sights)</p>
                    <p><span class="key">L</span> Fire</p>
                    <p><span class="key">K</span> Reload</p>
                </div>
            </div>
            
            <p style="opacity: 0.5; font-size: 12px; margin-top: 20px; max-width: 500px; text-align: center;">
                No crosshairs. Iron sights only. Full reloading process required after each shot.
                First to draw blood wins honor.
            </p>
            
            <button class="start-btn" onclick="startGame()">Accept the Challenge</button>
        </div>
        
        <div class="victory-screen" id="victory-screen">
            <h2 id="victor-text">Player 1 Claims Victory!</h2>
            <p id="victor-subtext">Honor has been satisfied.</p>
            <button class="start-btn" onclick="resetGame()">Duel Again</button>
        </div>
        
        <div class="center-line"></div>
        
        <div class="player-view" id="player1-view">
            <div class="player-label">Duelist I</div>
            <canvas id="canvas1"></canvas>
            <div class="flash-overlay" id="flash1"></div>
            <div class="ui-overlay">
                <div class="reloading-indicator" id="reload1" style="display: none;">
                    <div class="reloading-bar">
                        <div class="reloading-progress" id="reload-progress1"></div>
                    </div>
                    <div class="reloading-step" id="reload-step1">Loading...</div>
                </div>
            </div>
            <div class="ammo-counter" id="ammo1">1/1</div>
        </div>
        
        <div class="player-view" id="player2-view">
            <div class="player-label">Duelist II</div>
            <canvas id="canvas2"></canvas>
            <div class="flash-overlay" id="flash2"></div>
            <div class="ui-overlay">
                <div class="reloading-indicator" id="reload2" style="display: none;">
                    <div class="reloading-bar">
                        <div class="reloading-progress" id="reload-progress2"></div>
                    </div>
                    <div class="reloading-step" id="reload-step2">Loading...</div>
                </div>
            </div>
            <div class="ammo-counter" id="ammo2">1/1</div>
        </div>
    </div>

    <!-- Three.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    
    <script src="js/musket.js"></script>
    <script src="js/player.js"></script>
    <script src="js/ballistics.js"></script>
    <script src="js/game.js"></script>
</body>
</html>
