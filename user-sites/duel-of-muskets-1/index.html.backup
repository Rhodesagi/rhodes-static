<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Duel of Muskets - 2 Player Flintlock Duel</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { 
            width: 100%; 
            height: 100%; 
            overflow: hidden; 
            background: #000; 
            font-family: 'Courier New', monospace;
        }
        #game-container {
            width: 100vw;
            height: 100vh;
            position: relative;
        }
        #canvas-container {
            width: 100%;
            height: 100%;
        }
        #ui-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }
        .health-bar {
            position: absolute;
            height: 20px;
            background: linear-gradient(90deg, #ff3333, #ff6666);
            border: 2px solid #fff;
            border-radius: 4px;
            top: 10px;
        }
        #p1-health {
            left: 10px;
            width: 48%;
        }
        #p2-health {
            right: 10px;
            width: 48%;
        }
        .player-label {
            position: absolute;
            top: 35px;
            color: #fff;
            font-weight: bold;
            font-size: 14px;
            text-shadow: 2px 2px 0 #000;
        }
        #p1-label { left: 10px; }
        #p2-label { right: 10px; text-align: right; }
        .reload-indicator {
            position: absolute;
            bottom: 80px;
            color: #fff;
            font-size: 12px;
            background: rgba(0,0,0,0.7);
            padding: 5px 10px;
            border-radius: 4px;
            display: none;
        }
        #p1-reload { left: 10px; }
        #p2-reload { right: 10px; text-align: right; }
        #center-divider {
            position: absolute;
            left: 50%;
            top: 0;
            width: 4px;
            height: 100%;
            background: linear-gradient(to bottom, 
                transparent, 
                rgba(255,255,255,0.8) 20%, 
                rgba(255,255,255,0.8) 80%, 
                transparent);
            transform: translateX(-50%);
        }
        #start-screen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.9);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: #fff;
            z-index: 100;
            pointer-events: auto;
        }
        #start-screen h1 {
            font-size: 48px;
            margin-bottom: 20px;
            text-shadow: 4px 4px 0 #8B4513;
            letter-spacing: 4px;
        }
        .controls-panel {
            display: flex;
            gap: 40px;
            margin-top: 20px;
        }
        .player-controls {
            background: rgba(139, 69, 19, 0.3);
            padding: 20px;
            border: 2px solid #8B4513;
            border-radius: 8px;
            min-width: 250px;
        }
        .player-controls h3 {
            color: #DEB887;
            margin-bottom: 10px;
            border-bottom: 1px solid #8B4513;
            padding-bottom: 5px;
        }
        .control-row {
            display: flex;
            justify-content: space-between;
            margin: 5px 0;
            font-size: 13px;
        }
        .key {
            background: #333;
            padding: 2px 8px;
            border-radius: 4px;
            border: 1px solid #666;
        }
        #start-btn {
            margin-top: 30px;
            padding: 15px 40px;
            font-size: 24px;
            background: #8B4513;
            color: #fff;
            border: 3px solid #DEB887;
            border-radius: 8px;
            cursor: pointer;
            font-family: inherit;
            letter-spacing: 2px;
            transition: all 0.2s;
        }
        #start-btn:hover {
            background: #A0522D;
            transform: scale(1.05);
        }
        #win-screen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.9);
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: #fff;
            z-index: 100;
            pointer-events: auto;
        }
        #win-screen h2 {
            font-size: 36px;
            margin-bottom: 20px;
        }
        #restart-btn {
            padding: 12px 30px;
            font-size: 18px;
            background: #228B22;
            color: #fff;
            border: 2px solid #90EE90;
            border-radius: 6px;
            cursor: pointer;
            font-family: inherit;
        }
    </style>
</head>
<body>
    <div id="game-container">
        <div id="canvas-container"></div>
        
        <div id="ui-overlay">
            <div id="center-divider"></div>
            <div id="p1-health" class="health-bar"></div>
            <div id="p2-health" class="health-bar"></div>
            <div id="p1-label" class="player-label">PLAYER 1</div>
            <div id="p2-label" class="player-label">PLAYER 2</div>
            <div id="p1-reload" class="reload-indicator"></div>
            <div id="p2-reload" class="reload-indicator"></div>
        </div>

        <div id="start-screen">
            <h1>⚔️ DUEL OF MUSKETS ⚔️</h1>
            <p>2-Player Flintlock Pistol Duel • First Blood Wins</p>
            <div class="controls-panel">
                <div class="player-controls">
                    <h3>PLAYER 1 (Left Screen)</h3>
                    <div class="control-row"><span>Move</span><span><span class="key">W</span><span class="key">A</span><span class="key">S</span><span class="key">D</span></span></div>
                    <div class="control-row"><span>Rotate Weapon</span><span><span class="key">Q</span><span class="key">E</span></span></div>
                    <div class="control-row"><span>Aim Iron Sights</span><span><span class="key">X</span></span></div>
                    <div class="control-row"><span>Fire</span><span><span class="key">F</span></span></div>
                    <div class="control-row"><span>Reload</span><span><span class="key">R</span></span></div>
                </div>
                <div class="player-controls">
                    <h3>PLAYER 2 (Right Screen)</h3>
                    <div class="control-row"><span>Move</span><span><span class="key">I</span><span class="key">J</span><span class="key">K</span><span class="key">L</span></span></div>
                    <div class="control-row"><span>Rotate Weapon</span><span><span class="key">U</span><span class="key">O</span></span></div>
                    <div class="control-row"><span>Aim Iron Sights</span><span><span class="key">M</span></span></div>
                    <div class="control-row"><span>Fire</span><span><span class="key">Y</span></span></div>
                    <div class="control-row"><span>Reload</span><span><span class="key">H</span></span></div>
                </div>
            </div>
            <button id="start-btn">CLICK TO START</button>
        </div>

        <div id="win-screen">
            <h2 id="winner-text"></h2>
            <button id="restart-btn">Duel Again</button>
        </div>
    </div>

    <script type="importmap">
    {
        "imports": {
            "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
            "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
        }
    }
    </script>
    <script type="module" src="js/main.js"></script>
</body>
</html>